@inject LedgerService Svc

<div class="panel">
    <div class="panel-head">
        <h3>固定費設定</h3>
        <button class="btn" @onclick="AddFixedCost">＋ 追加</button>
    </div>

    @if (Svc.State.FixedCosts.Count == 0)
    {
        <div class="none">固定費が登録されていません。</div>
    }
    else
    {
        <div class="fc-head">
            <span>項目名</span><span>口座</span><span>通常月金額</span><span></span>
        </div>

        @foreach (var fc in Svc.State.FixedCosts)
        {
            var expanded = ExpandedIds.Contains(fc.Id);
            <div class="fc-item">
                <div class="fc-row">
                    <input value="@fc.Name" placeholder="項目名"
                           @onchange="e => OnFcNameChange(fc, e.Value)" />
                    <select value="@fc.AccountId"
                            @onchange="e => OnFcAccountChange(fc, e.Value)">
                        <option value="">口座を選択</option>
                        @foreach (var a in Svc.ActiveAccounts)
                        {
                            <option value="@a.Id" selected="@(fc.AccountId == a.Id)">@a.Name</option>
                        }
                    </select>
                    <AmountInput CssClass="ra" Value="@fc.Amount" ValueChanged="v => { fc.Amount = v; SaveWithReload(); }" />
                    <button class="x" @onclick="() => RemoveFixedCost(fc.Id)">✕</button>
                </div>

                <button class="fc-expand" @onclick="() => ToggleExpand(fc.Id)">
                    @(expanded ? "▼" : "▶") 期間・ボーナス設定（@SummaryText(fc)）
                </button>

                @if (expanded)
                {
                    <div class="fc-detail">
                        <div class="detail-row">
                            <span class="detail-lab">開始年月</span>
                            <select value="@StartYear(fc)"
                                    @onchange="e => SetStartYear(fc, e.Value?.ToString())">
                                <option value="">未設定</option>
                                @foreach (var y in YearRange())
                                {
                                    <option value="@y">@y 年</option>
                                }
                            </select>
                            <select value="@StartMonth(fc)"
                                    @onchange="e => SetStartMonth(fc, e.Value?.ToString())">
                                <option value="">—</option>
                                @for (int mi = 1; mi <= 12; mi++)
                                {
                                    var label = mi + " 月";
                                    var val = mi.ToString();
                                    <option value="@val">@label</option>
                                }
                            </select>
                        </div>
                        <div class="detail-row">
                            <span class="detail-lab">終了年月</span>
                            <select value="@EndYear(fc)"
                                    @onchange="e => SetEndYear(fc, e.Value?.ToString())">
                                <option value="">未設定</option>
                                @foreach (var y in YearRange())
                                {
                                    <option value="@y">@y 年</option>
                                }
                            </select>
                            <select value="@EndMonth(fc)"
                                    @onchange="e => SetEndMonth(fc, e.Value?.ToString())">
                                <option value="">—</option>
                                @for (int mi = 1; mi <= 12; mi++)
                                {
                                    var label = mi + " 月";
                                    var val = mi.ToString();
                                    <option value="@val">@label</option>
                                }
                            </select>
                        </div>
                        <div class="detail-row" style="flex-direction:column;align-items:flex-start;gap:6px">
                            <span class="detail-lab">ボーナス払い</span>
                            @if (fc.BonusSettings.Count > 0)
                            {
                                <div class="bonus-list">
                                    <div class="bonus-row-head">
                                        <span>対象月</span><span>種別</span><span>金額</span><span></span>
                                    </div>
                                    @foreach (var b in fc.BonusSettings)
                                    {
                                        <div class="bonus-row">
                                            <select value="@b.Month.ToString()"
                                                    @onchange="e => OnBonusMonthChange(b, e.Value)">
                                                @for (int mi = 1; mi <= 12; mi++)
                                                {
                                                    var label = mi + " 月";
                                                    var val = mi.ToString();
                                                    <option value="@val" selected="@(b.Month == mi)">@label</option>
                                                }
                                            </select>
                                            <select value="@b.Type.ToString()"
                                                    @onchange="e => OnBonusTypeChange(b, e.Value)">
                                                <option value="Add" selected="@(b.Type == BonusType.Add)">上乗せ</option>
                                                <option value="Separate" selected="@(b.Type == BonusType.Separate)">別額</option>
                                            </select>
                                            <AmountInput CssClass="ra" Value="@b.Amount" ValueChanged="v => { b.Amount = v; SaveWithReload(); }" />
                                            <button class="x" @onclick="() => RemoveBonus(fc, b.Id)">✕</button>
                                        </div>
                                    }
                                </div>
                            }
                            <button class="add-line" @onclick="() => AddBonus(fc)">＋ ボーナス月を追加</button>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<div class="foot">
    開始・終了年月は任意です（未設定 = 開始なし / 無期限）。終了月はその月を含みます。<br />
    マスタの変更は未作成の月を開いたときから反映されます。作成済みの月は月次管理の「↺ 再読み込み」で手動反映できます。
</div>

@code {
    private HashSet<string> ExpandedIds = new();
    private void Save() => _ = Svc.SaveAsync();
    private void SaveWithReload() { Svc.OnFixedCostChanged(); _ = Svc.SaveAsync(); }
    private void ToggleExpand(string id) { if (!ExpandedIds.Remove(id)) ExpandedIds.Add(id); }

    private void OnFcNameChange(FixedCost fc, object? v) { fc.Name = v?.ToString() ?? ""; SaveWithReload(); }
    private void OnFcAccountChange(FixedCost fc, object? v) { fc.AccountId = v?.ToString() ?? ""; SaveWithReload(); }
    private void OnBonusMonthChange(BonusSetting b, object? v) { b.Month = int.TryParse(v?.ToString(), out var m) ? m : 1; SaveWithReload(); }
    private void OnBonusTypeChange(BonusSetting b, object? v) { b.Type = v?.ToString() == "Add" ? BonusType.Add : BonusType.Separate; SaveWithReload(); }

    private void AddFixedCost() { Svc.State.FixedCosts.Add(new FixedCost()); SaveWithReload(); }
    private void RemoveFixedCost(string id) { Svc.State.FixedCosts.RemoveAll(f => f.Id == id); SaveWithReload(); }
    private void AddBonus(FixedCost fc) { fc.BonusSettings.Add(new BonusSetting { Month = 6 }); SaveWithReload(); }
    private void RemoveBonus(FixedCost fc, string bid) { fc.BonusSettings.RemoveAll(b => b.Id == bid); SaveWithReload(); }

    private static decimal ParseDecimal(object? v) =>
        decimal.TryParse(v?.ToString()?.Replace(",", ""), out var d) ? d : 0;
    private static IEnumerable<int> YearRange() => Enumerable.Range(DateTime.Today.Year - 5, 31);

    private static string StartYear(FixedCost fc) => fc.StartYm != null && fc.StartYm.Length >= 4 ? fc.StartYm[..4] : "";
    private static string StartMonth(FixedCost fc) => fc.StartYm != null && fc.StartYm.Length == 6 ? int.Parse(fc.StartYm[4..]).ToString() : "";
    private static string EndYear(FixedCost fc) => fc.EndYm != null && fc.EndYm.Length >= 4 ? fc.EndYm[..4] : "";
    private static string EndMonth(FixedCost fc) => fc.EndYm != null && fc.EndYm.Length == 6 ? int.Parse(fc.EndYm[4..]).ToString() : "";

    private void SetStartYear(FixedCost fc, string? y)
    {
        if (string.IsNullOrEmpty(y)) { fc.StartYm = null; SaveWithReload(); return; }
        var m = StartMonth(fc);
        fc.StartYm = !string.IsNullOrEmpty(m) ? string.Format("{0}{1:D2}", y, int.Parse(m)) : y;
        SaveWithReload();
    }
    private void SetStartMonth(FixedCost fc, string? m)
    {
        var y = StartYear(fc);
        if (string.IsNullOrEmpty(m)) { fc.StartYm = y.Length == 4 ? y : null; SaveWithReload(); return; }
        fc.StartYm = !string.IsNullOrEmpty(y) ? string.Format("{0}{1:D2}", y, int.Parse(m)) : null;
        SaveWithReload();
    }
    private void SetEndYear(FixedCost fc, string? y)
    {
        if (string.IsNullOrEmpty(y)) { fc.EndYm = null; SaveWithReload(); return; }
        var m = EndMonth(fc);
        fc.EndYm = !string.IsNullOrEmpty(m) ? string.Format("{0}{1:D2}", y, int.Parse(m)) : y;
        SaveWithReload();
    }
    private void SetEndMonth(FixedCost fc, string? m)
    {
        var y = EndYear(fc);
        if (string.IsNullOrEmpty(m)) { fc.EndYm = y.Length == 4 ? y : null; SaveWithReload(); return; }
        fc.EndYm = !string.IsNullOrEmpty(y) ? string.Format("{0}{1:D2}", y, int.Parse(m)) : null;
        SaveWithReload();
    }

    private static string SummaryText(FixedCost fc)
    {
        string start, end;
        if (fc.StartYm == null)
            start = "開始なし〜";
        else if (fc.StartYm.Length == 6)
            start = string.Format("{0}年{1}月〜", fc.StartYm[..4], int.Parse(fc.StartYm[4..]));
        else
            start = fc.StartYm + "年〜";

        if (fc.EndYm == null)
            end = "無期限";
        else if (fc.EndYm.Length == 6)
            end = string.Format("{0}年{1}月", fc.EndYm[..4], int.Parse(fc.EndYm[4..]));
        else
            end = fc.EndYm + "年";

        var bonus = fc.BonusSettings.Count > 0 ? string.Format("ボーナス{0}件", fc.BonusSettings.Count) : "ボーナスなし";
        return string.Format("{0}{1}・{2}", start, end, bonus);
    }
}
