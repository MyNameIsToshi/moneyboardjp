@page "/portfolio"
@implements IDisposable
@using ApexCharts
@inject PortfolioStore Store
@inject QuoteService Quote
@inject NavigationManager Nav

<div class="wrap">
    <div class="pf-head">
        <div class="app-title">ポートフォリオ</div>
        <button class="btn" @onclick='() => Nav.NavigateTo("/")'>← 戻る</button>
    </div>

    @if (Store.IsPending)
    {
        <div class="loading"><p class="pending-title">アクセス承認待ちです</p></div>
    }
    else if (LoadFailed)
    {
        <div class="loading">
            データの読み込みに失敗しました。<br />
            ネットワーク接続を確認して、再度お試しください。<br />
            <button class="btn" @onclick="Load">再読み込み</button>
        </div>
    }
    else if (!Loaded)
    {
        <div class="loading"><div class="spinner"></div>読み込み中…</div>
    }
    else
    {
        <div class="pf-summary-bar">
            <div class="pf-sum-main">
                <span class="pf-sum-label">総資産（円）</span>
                <span class="pf-sum-total">@TotalJpyDisplay</span>
                <div class="pf-sum-sub">
                    <span>元本 ¥@TotalCostJpy.ToString("#,0")</span>
                    <span>評価損益 <b class="@PnlClass(TotalPnlJpy)">@SignedYen(TotalPnlJpy)@PnlPct(TotalPnlJpy, TotalCostJpy)</b></span>
                </div>
            </div>
            <div class="pf-sum-meta">
                @if (!string.IsNullOrEmpty(Store.Data.PricedAt))
                {
                    <span>価格更新 @Store.Data.PricedAt</span>
                    @if (Store.Data.UsdJpyRate > 0)
                    {
                        <span>・USD/JPY @Store.Data.UsdJpyRate.ToString("#,0.##")</span>
                    }
                }
                <button class="btn-sm" disabled="@_updating" @onclick="() => UpdatePrices()">@(_updating ? "更新中…" : "価格更新")</button>
            </div>
        </div>
        @if (_updateMsg != null)
        {
            <div class="pf-hint pf-neg">@_updateMsg</div>
        }

        @* ── 資産構成（クラス別／銘柄別の構成比ドーナツ）── *@
        @if (CompositionData.Count > 0)
        {
            <div class="cat-head" style="margin-top:6px">
                <span>資産構成</span>
                <div class="pf-comp-toggle">
                    <button class="period-btn @(_compMode == "class" ? "active" : "")" @onclick='() => SetCompMode("class")'>クラス別</button>
                    <button class="period-btn @(_compMode == "holding" ? "active" : "")" @onclick='() => SetCompMode("holding")'>銘柄別</button>
                </div>
            </div>
            <div class="graph-card graph-card-full pf-comp-card">
                <div class="spend">
                    <div class="spend-chart">
                        <ApexChart TItem="SpendSlice" Options="CompDonutOptions" @key="@($"comp-{_compMode}-{_compRev}")">
                            <ApexPointSeries TItem="SpendSlice"
                                             Items="CompositionData"
                                             SeriesType="SeriesType.Donut"
                                             Name="資産構成"
                                             XValue="@(e => e.Label)"
                                             YValue="@(e => e.Value)" />
                        </ApexChart>
                    </div>
                    <div class="spend-list">
                        <div class="spend-row spend-head">
                            <span></span><span>@(_compMode == "class" ? "資産クラス" : "銘柄")</span><span>評価額</span><span>割合</span>
                        </div>
                        @foreach (var s in CompositionData)
                        {
                            <div class="spend-row">
                                <span class="color-dot" style="background:@s.Color"></span>
                                <span class="spend-name">@s.Label</span>
                                <span class="spend-amt">¥@s.Value.ToString("#,0")</span>
                                <span class="spend-pct">@CompPct(s.Value)</span>
                            </div>
                        }
                        <div class="spend-row spend-total">
                            <span></span><span>合計</span>
                            <span class="spend-amt">¥@CompTotal.ToString("#,0")</span>
                            <span></span>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* ── 推移（総資産・評価損益・配当の時系列。価格更新のたびに1日1点が記録される）── *@
        @if (AssetSeries.Count > 0 || DivSeries.Count > 0)
        {
            <div class="cat-head" style="margin-top:18px"><span>推移</span></div>
            <div class="graph-grid">
                @if (AssetSeries.Count > 0)
                {
                    <div class="graph-card">
                        <h4>総資産の推移</h4>
                        <ApexChart TItem="ChartPoint" Options="AssetLineOpt" @key="@($"asset-{_compRev}")">
                            <ApexPointSeries TItem="ChartPoint" Items="AssetSeries" SeriesType="SeriesType.Line"
                                             Name="総資産" XValue="@(e => e.Label)" YValue="@(e => e.Value)" />
                        </ApexChart>
                    </div>
                    <div class="graph-card">
                        <h4>評価損益の推移</h4>
                        <ApexChart TItem="ChartPoint" Options="PnlLineOpt" @key="@($"pnl-{_compRev}")">
                            <ApexPointSeries TItem="ChartPoint" Items="PnlSeries" SeriesType="SeriesType.Line"
                                             Name="評価損益" XValue="@(e => e.Label)" YValue="@(e => e.Value)" />
                        </ApexChart>
                    </div>
                }
                @if (DivSeries.Count > 0)
                {
                    <div class="graph-card">
                        <h4>配当・分配金の累計</h4>
                        <ApexChart TItem="ChartPoint" Options="DivLineOpt" @key="@($"div-{_compRev}")">
                            <ApexPointSeries TItem="ChartPoint" Items="DivSeries" SeriesType="SeriesType.Area"
                                             Name="配当累計" XValue="@(e => e.Label)" YValue="@(e => e.Value)" />
                        </ApexChart>
                    </div>
                }
            </div>
            @if (AssetSeries.Count == 1)
            {
                <div class="pf-hint">推移は「価格更新」のたびに1日1点が記録されます。日を追うごとにグラフが伸びていきます。</div>
            }
        }

        <div class="cat-head">
            <span>保有銘柄</span>
            <button class="btn" @onclick="OpenAdd">＋ 追加</button>
        </div>

        @if (!Ordered.Any())
        {
            <div class="none">銘柄が登録されていません。「＋ 追加」から取引を登録してください。</div>
        }
        else
        {
            @foreach (var grp in Groups)
            {
                var items = Ordered.Where(h => h.Class == grp.Class).ToList();
                if (items.Count == 0) continue;
                <div class="pf-group-head">@grp.Label</div>
                <div class="pf-grid pf-grid-head">
                    <span>銘柄名</span><span>口座</span>
                    <span class="pf-num">数量</span><span class="pf-num">平均取得単価</span>
                    <span class="pf-num">評価額</span><span class="pf-num">評価損益</span>
                    <span></span><span></span>
                </div>
                @foreach (var h in items)
                {
                    var s = Summary(h);
                    var val = Valuation(h, s.Quantity);
                    var upnl = UnrealizedPnl(h, s);
                    <div class="pf-grid pf-row @(_dragOverId == h.Id ? "pf-drag-over" : "")"
                         draggable="true" @key="h.Id"
                         @ondragstart="() => _dragId = h.Id"
                         @ondragenter="() => _dragOverId = h.Id"
                         @ondragover:preventDefault="true"
                         @ondragleave="() => OnDragLeave(h.Id)"
                         @ondrop="() => OnDrop(h)"
                         @ondrop:preventDefault="true"
                         @ondragend="OnDragEnd">
                        <span class="pf-hname" title="@DisplayName(h)"><span class="pf-drag-handle" title="ドラッグで並べ替え">⠿</span>@DisplayName(h)</span>
                        <span class="pf-badge">@AccountLabel(h.Account)</span>
                        <span class="pf-num">@Qty(s.Quantity)</span>
                        <span class="pf-num">@Price(h, s.AvgUnitPrice)</span>
                        <span class="pf-num">@MoneyOpt(h, val)</span>
                        <span class="pf-num @PnlClass(upnl ?? 0)">@MoneySignedOpt(h, upnl)<span class="pf-pnl-pct">@PnlPct(upnl, s.CostBasis)</span></span>
                        <button class="btn-sm" @onclick="() => OpenTx(h.Id)">取引</button>
                        <button class="x" @onclick="() => AskDelete(h)">✕</button>
                    </div>
                }
            }
        }

        <div class="foot" style="text-align:left;margin-top:10px">
            「＋ 追加」で新規銘柄を登録すると保有銘柄として表示されます。同じ銘柄は合算されます。<br />
            各銘柄の「取引」で買付・売却・配当の追加/編集と銘柄設定ができます。投資信託は基準価額＝1万口あたりとして計算します。<br />
            「価格更新」で現在価格と USD/JPY を取得します（日本株＝証券コード4桁／米国株＝ティッカー／投資信託＝協会コード）。コード未設定の投資信託は「取引」で現在基準価額を手入力できます。
        </div>
    }
</div>

@* ── 新規銘柄登録ダイアログ（誤クリック防止のためダイアログ外クリックでは閉じない）── *@
@if (_addOpen)
{
    <div class="dialog-overlay">
        <div class="dialog-box pf-add-box" @onclick:stopPropagation="true">
            <h4>新規銘柄登録</h4>
            <div class="pf-add-form">
                <label>資産クラス
                    <select @bind="_nClass">
                        <option value="@AssetClass.Fund">投資信託</option>
                        <option value="@AssetClass.JpStock">日本株</option>
                        <option value="@AssetClass.UsStock">米国株</option>
                    </select>
                </label>
                <label>口座区分
                    <select @bind="_nAccount">
                        <option value="@AccountKind.NisaGrowth">NISA（成長投資枠）</option>
                        <option value="@AccountKind.NisaTsumitate">NISA（つみたて投資枠）</option>
                        <option value="@AccountKind.Tokutei">特定</option>
                        <option value="@AccountKind.General">一般</option>
                    </select>
                </label>
                @if (_nClass == AssetClass.UsStock)
                {
                    <label>建て通貨
                        <select @bind="_nCurrency">
                            <option value="@Currency.Jpy">円建て</option>
                            <option value="@Currency.Usd">ドル建て</option>
                        </select>
                    </label>
                }

                @if (_nClass == AssetClass.Fund)
                {
                    <label>投信を選択
                        <select @bind="_nFundPick" @bind:after="OnFundPicked">
                            <option value="">― 一覧から選択 ―</option>
                            @foreach (var f in FundMaster.Items)
                            {
                                <option value="@f.Code">@f.Name</option>
                            }
                            <option value="__other">その他（一覧に無い投信）</option>
                        </select>
                    </label>
                    @if (_nFundPick == "__other")
                    {
                        <label>銘柄名
                            <input @bind="_nName" placeholder="例 ○○インデックスファンド" />
                        </label>
                        <label>協会コード
                            <input @bind="_nAssocFundCd" placeholder="例 0331418A" />
                        </label>
                        <span class="pf-hint">協会コード（8桁）を入れると「価格更新」で基準価額を自動取得します。未入力でも現在基準価額は手入力できます。</span>
                    }
                }
                else
                {
                    <label>銘柄名
                        <input @bind="_nName" placeholder="@(_nClass == AssetClass.JpStock ? "例 トヨタ自動車" : "例 アップル")" />
                    </label>
                    @if (_nClass == AssetClass.JpStock)
                    {
                        <label>証券コード（4桁）
                            <input @bind="_nSymbol" placeholder="例 7203 / 9432" />
                        </label>
                    }
                    else
                    {
                        <label>ティッカー
                            <input @bind="_nSymbol" placeholder="例 AAPL / TSM" />
                        </label>
                    }
                }

                <div class="pf-add-buy">
                    <span class="pf-add-buy-title">買付</span>
                    <label>約定日 <input type="date" value="@_bDate" @onchange="e => _bDate = e.Value?.ToString() ?? string.Empty" /></label>
                    <label>数量 <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@_bQty" ValueChanged="v => _bQty = v" /></label>
                    <label>@BuyPriceLabel <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@_bPrice" ValueChanged="v => _bPrice = v" /></label>
                </div>
            </div>
            <div class="dialog-btns">
                <button class="btn" @onclick="CloseAdd">キャンセル</button>
                <button class="btn primary" disabled="@(!CanAdd)" @onclick="SubmitAdd">登録</button>
            </div>
        </div>
    </div>
}

@* ── 取引・設定ダイアログ（既存銘柄）── *@
@if (_txHoldingId != null)
{
    var h = HoldingById(_txHoldingId);
    if (h != null)
    {
        var s = Summary(h);
        <div class="dialog-overlay" @onclick="CloseTx">
            <div class="dialog-box pf-tx-box" @onclick:stopPropagation="true">
                <h4>@DisplayName(h) の取引・設定</h4>

                <div class="pf-tx-settings">
                    <label>銘柄名 <input @bind="h.Name" @bind:after="TxSave" /></label>
                    <label>資産クラス
                        <select @bind="h.Class" @bind:after="() => OnClassChanged(h)">
                            <option value="@AssetClass.Fund">投資信託</option>
                            <option value="@AssetClass.JpStock">日本株</option>
                            <option value="@AssetClass.UsStock">米国株</option>
                        </select>
                    </label>
                    <label>口座区分
                        <select @bind="h.Account" @bind:after="TxSave">
                            <option value="@AccountKind.NisaGrowth">NISA（成長投資枠）</option>
                            <option value="@AccountKind.NisaTsumitate">NISA（つみたて投資枠）</option>
                            <option value="@AccountKind.Tokutei">特定</option>
                            <option value="@AccountKind.General">一般</option>
                            @if (h.Account == AccountKind.Nisa)
                            {
                                <option value="@AccountKind.Nisa">NISA（旧・未分類）</option>
                            }
                        </select>
                    </label>
                    @if (h.Class == AssetClass.UsStock)
                    {
                        <label>建て通貨
                            <select @bind="h.CostCurrency" @bind:after="TxSave">
                                <option value="@Currency.Jpy">円建て</option>
                                <option value="@Currency.Usd">ドル建て</option>
                            </select>
                        </label>
                    }
                    @if (h.Class == AssetClass.JpStock)
                    {
                        <label>証券コード <input @bind="h.Symbol" @bind:after="TxSave" placeholder="例 7203 / 9432" /></label>
                    }
                    else if (h.Class == AssetClass.UsStock)
                    {
                        <label>ティッカー <input @bind="h.Symbol" @bind:after="TxSave" placeholder="例 AAPL / TSM" /></label>
                    }
                    else
                    {
                        <label>投信を選択
                            <select value="@h.AssocFundCd" @onchange="e => OnTxFundPicked(h, e.Value?.ToString())">
                                <option value="">― 一覧から選択 ―</option>
                                @foreach (var f in FundMaster.Items)
                                {
                                    <option value="@f.Code">@f.Name</option>
                                }
                            </select>
                        </label>
                        <label>協会コード <input @bind="h.AssocFundCd" @bind:after="TxSave" placeholder="例 0331418A" /></label>
                    }
                </div>

                @if (h.Class == AssetClass.UsStock)
                {
                    <div class="pf-hint">円建て＝単価は「円/株」（拠出した円÷株数・為替入力は不要）／ドル建て＝単価は「$/株」。現在価格は後の段階で自動取得して評価額に反映します。</div>
                }

                <div class="pf-tx-price">
                    <label>@CurPriceLabel(h)
                        <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@CurPrice(h.Id)" ValueChanged="v => SetCurPrice(h.Id, v)" />
                    </label>
                    @if (h.Class == AssetClass.UsStock)
                    {
                        <span class="pf-hint">米国株の現在価格は $/株。円換算は USD/JPY @(Store.Data.UsdJpyRate > 0 ? Store.Data.UsdJpyRate.ToString("#,0.##") : "未取得") を使用。</span>
                    }
                </div>

                <div class="pf-tx-summary">
                    <span>数量 <b>@Qty(s.Quantity)</b></span>
                    <span>平均取得単価 <b>@Price(h, s.AvgUnitPrice)</b></span>
                    <span>取得原価 <b>@Money(h, s.CostBasis)</b></span>
                    <span>評価額 <b>@MoneyOpt(h, Valuation(h, s.Quantity))</b></span>
                    <span>評価損益 <b class="@PnlClass(UnrealizedPnl(h, s) ?? 0)">@MoneySignedOpt(h, UnrealizedPnl(h, s))@PnlPct(UnrealizedPnl(h, s), s.CostBasis)</b></span>
                    <span>実現損益 <b class="@PnlClass(s.RealizedPnl)">@MoneySigned(h, s.RealizedPnl)</b></span>
                    <span>配当合計 <b>@Money(h, s.Dividends)</b></span>
                </div>

                @* 買付 *@
                <div class="pf-tx-sec">
                    <div class="pf-tx-sec-head"><span>買付</span><button class="btn-sm" @onclick="() => AddBuy(h.Id)">＋ 追加</button></div>
                    @if (BuysOf(h.Id).Any())
                    {
                        <div class="pf-tx-grid pf-tx-grid-head"><span>約定日</span><span class="pf-num">数量</span><span class="pf-num">@UnitLabel(h)</span><span></span></div>
                        @foreach (var b in BuysOf(h.Id))
                        {
                            <div class="pf-tx-grid">
                                <input type="date" class="pf-tx-date" value="@b.Date" @onchange="e => OnBuyDate(b, e.Value)" />
                                <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@b.Quantity" ValueChanged="v => { b.Quantity = v; TxSave(); }" />
                                <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@b.UnitPrice" ValueChanged="v => { b.UnitPrice = v; TxSave(); }" />
                                <button class="x" @onclick="() => RemoveBuy(b.Id)">✕</button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="none">買付の記録はありません。</div>
                    }
                </div>

                @* 売却 *@
                <div class="pf-tx-sec">
                    <div class="pf-tx-sec-head"><span>売却（解約）</span><button class="btn-sm" @onclick="() => AddSell(h.Id)">＋ 追加</button></div>
                    @if (SellsOf(h.Id).Any())
                    {
                        <div class="pf-tx-grid pf-tx-grid-head"><span>約定日</span><span class="pf-num">数量</span><span class="pf-num">@UnitLabel(h)</span><span></span></div>
                        @foreach (var sl in SellsOf(h.Id))
                        {
                            <div class="pf-tx-grid">
                                <input type="date" class="pf-tx-date" value="@sl.Date" @onchange="e => OnSellDate(sl, e.Value)" />
                                <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@sl.Quantity" ValueChanged="v => { sl.Quantity = v; TxSave(); }" />
                                <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@sl.UnitPrice" ValueChanged="v => { sl.UnitPrice = v; TxSave(); }" />
                                <button class="x" @onclick="() => RemoveSell(sl.Id)">✕</button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="none">売却の記録はありません。</div>
                    }
                </div>

                @* 配当 *@
                <div class="pf-tx-sec">
                    <div class="pf-tx-sec-head"><span>配当・分配金</span><button class="btn-sm" @onclick="() => AddDiv(h.Id)">＋ 追加</button></div>
                    @if (DivsOf(h.Id).Any())
                    {
                        <div class="pf-tx-grid pf-tx-grid-head"><span>受取日</span><span class="pf-num">金額</span><span></span><span></span></div>
                        @foreach (var dv in DivsOf(h.Id))
                        {
                            <div class="pf-tx-grid">
                                <input type="date" class="pf-tx-date" value="@dv.Date" @onchange="e => OnDivDate(dv, e.Value)" />
                                <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@dv.Amount" ValueChanged="v => { dv.Amount = v; TxSave(); }" />
                                <span></span>
                                <button class="x" @onclick="() => RemoveDiv(dv.Id)">✕</button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="none">配当の記録はありません。</div>
                    }
                </div>

                <div class="dialog-btns"><button class="btn" @onclick="CloseTx">閉じる</button></div>
            </div>
        </div>
    }
}

<ConfirmDialog IsVisible="@ShowConfirm"
               Title="銘柄を削除しますか？"
               Message="@ConfirmMessage"
               ConfirmText="削除する"
               OnConfirm="ExecuteDelete"
               OnCancel="() => ShowConfirm = false" />

@code {
    private bool Loaded;
    private bool LoadFailed;

    // 表示するカテゴリ（順番＝日本株→米国株→投資信託）
    private static readonly (AssetClass Class, string Label)[] Groups =
    {
        (AssetClass.JpStock, "日本株"),
        (AssetClass.UsStock, "米国株"),
        (AssetClass.Fund, "投資信託"),
    };

    private IEnumerable<Holding> Ordered =>
        Store.Data.Holdings.Where(h => !h.IsDeleted).OrderBy(h => h.SortOrder);

    private HoldingSummary Summary(Holding h) =>
        PortfolioMath.Summarize(h, Store.Data.Buys, Store.Data.Sells, Store.Data.Dividends);

    protected override async Task OnInitializedAsync()
    {
        Store.StateReloadedExternally += OnReload;
        await Load();
    }

    public void Dispose() => Store.StateReloadedExternally -= OnReload;
    private void OnReload() => InvokeAsync(StateHasChanged);

    private async Task Load()
    {
        Loaded = false;
        LoadFailed = false;
        if (await Store.LoadAsync())
        {
            Loaded = true;
            // 既存データ（前回の価格・スナップショット）でまずグラフを描く（自動更新失敗時もここまでは出る）。
            BuildComposition();
            BuildTimeSeries();
            // 画面を開いたら現在価格を自動更新（失敗・一部未取得のメッセージは出さない）。
            await UpdatePrices(manual: false);
        }
        else if (!Store.IsPending) LoadFailed = true;
    }

    private void Save() => Store.RequestSave();

    // ── 表示ヘルパ ──
    private static string Qty(decimal v) => v.ToString("#,0.####");
    private static string CurSym(Holding h) => h.CostCurrency == Currency.Usd ? "$" : "¥";
    private static string Money(Holding h, decimal v) =>
        CurSym(h) + (h.CostCurrency == Currency.Usd ? v.ToString("#,0.##") : v.ToString("#,0"));
    private static string MoneySigned(Holding h, decimal v) => (v > 0 ? "+" : "") + Money(h, v);
    private static string Price(Holding h, decimal v) => CurSym(h) + v.ToString("#,0.##");
    // 評価額・評価損益は現在価格が無いと算出できないため null 許容。未取得は "—"。
    private static string MoneyOpt(Holding h, decimal? v) => v.HasValue ? Money(h, v.Value) : "—";
    private static string MoneySignedOpt(Holding h, decimal? v) => v.HasValue ? MoneySigned(h, v.Value) : "—";
    private static string PnlClass(decimal v) => v > 0 ? "pf-pos" : v < 0 ? "pf-neg" : "";
    // 評価損益率＝評価損益 ÷ 取得原価 ×100。金額の後ろに " (+12.3%)" として併記。価格未取得・原価0は空。
    private static string PnlPct(decimal? upnl, decimal costBasis)
    {
        if (!upnl.HasValue || costBasis == 0) return "";
        decimal p = upnl.Value / costBasis * 100m;
        return " (" + (p >= 0 ? "+" : "") + p.ToString("0.0") + "%)";
    }
