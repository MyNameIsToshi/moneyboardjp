    private void AddSell(string id) { Store.Data.Sells.Add(new SellLot { HoldingId = id, Date = DateTime.Today.ToString("yyyy-MM-dd") }); TxSave(); }
    private void RemoveSell(string lotId) { Store.Data.Sells.RemoveAll(s => s.Id == lotId); TxSave(); }
    private void AddDiv(string id) { Store.Data.Dividends.Add(new Dividend { HoldingId = id, Date = DateTime.Today.ToString("yyyy-MM-dd"), Currency = HoldingById(id)?.CostCurrency ?? Currency.Jpy }); TxSave(); }
    private void RemoveDiv(string divId) { Store.Data.Dividends.RemoveAll(d => d.Id == divId); TxSave(); }

    private void OnBuyDate(BuyLot b, object? v) { b.Date = v?.ToString() ?? ""; TxSave(); }
    private void OnSellDate(SellLot s, object? v) { s.Date = v?.ToString() ?? ""; TxSave(); }
    private void OnDivDate(Dividend d, object? v) { d.Date = v?.ToString() ?? ""; TxSave(); }
}
