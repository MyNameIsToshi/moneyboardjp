    // 資産クラス変更（編集バッファに反映）。米国株以外は円建て・投信はシンボル無し。
    private void OnClassChanged()
    {
        if (_editH == null) return;
        if (_editH.Class != AssetClass.UsStock) _editH.CostCurrency = Currency.Jpy;
