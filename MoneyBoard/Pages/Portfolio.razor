    {
        if (FundMaster.Items.FirstOrDefault(x => x.Code == _nFundPick) is { } f)
        {
            _nName = f.Name;
            _nAssocFundCd = f.Code;
            _nIsin = f.Isin ?? "";
        }
        else   // "" または "__other"
        {
            _nName = "";
            _nAssocFundCd = "";
            _nIsin = "";
        }
