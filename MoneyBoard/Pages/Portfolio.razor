@page "/portfolio"
@implements IDisposable
@using ApexCharts
@inject PortfolioStore Store
@inject QuoteService Quote

<div class="wrap">
    <div class="pf-sticky">
        <div class="pf-head">
            <AppTitle Subtitle="ポートフォリオ" />
        </div>

        @if (Loaded && !Store.IsPending && !LoadFailed)
        {
            <div class="pf-summary-bar">
                <div class="pf-sum-main">
                    <span class="pf-sum-label">総資産（円）</span>
                    <span class="pf-sum-total">@TotalJpyDisplay</span>
                    <div class="pf-sum-sub">
                        <span>元本 ¥@TotalCostJpy.ToString("#,0")</span>
                        <span>評価損益 <b class="@PnlClass(TotalPnlJpy)">@SignedYen(TotalPnlJpy)@PnlPct(TotalPnlJpy, TotalCostJpy)</b></span>
                    </div>
                </div>
                <div class="pf-sum-meta">
                    @if (!string.IsNullOrEmpty(Store.Data.PricedAt))
                    {
                        <span>価格更新 @Store.Data.PricedAt</span>
                        @if (Store.Data.UsdJpyRate > 0)
                        {
                            <span>・USD/JPY @Store.Data.UsdJpyRate.ToString("#,0.##")</span>
                        }
                    }
                    <button class="btn-sm" disabled="@_updating" @onclick="() => UpdatePrices()">@(_updating ? "更新中…" : "価格更新")</button>
                </div>
            </div>
            @* ── 市場指標バー（固定6本・総資産と同じ帯。日報用スクショに収める）── *@
            <div class="pf-index-bar">
                @foreach (var ix in MarketIndices)
                {
                    var pct = IndexPct(ix.Symbol);
                    <div class="pf-index-chip">
                        <span class="pf-ix-name">@ix.Label</span>
                        <span class="pf-ix-val">@IndexValueDisp(ix.Symbol, ix.Decimals)</span>
                        @if (pct.HasValue)
                        {
                            <span class="pf-ix-pct @PnlClass(pct.Value)">@DayPct(pct.Value)</span>
                        }
                        else
                        {
                            <span class="pf-ix-pct">—</span>
                        }
                    </div>
                }
            </div>
            @if (_updateMsg != null)
            {
                <div class="pf-hint pf-neg">@_updateMsg</div>
            }
        }
    </div>

    @if (Store.IsPending)
    {
        <div class="loading"><p class="pending-title">アクセス承認待ちです</p></div>
    }
    else if (LoadFailed)
    {
        <div class="loading">
            データの読み込みに失敗しました。<br />
            ネットワーク接続を確認して、再度お試しください。<br />
            <button class="btn" @onclick="Load">再読み込み</button>
        </div>
    }
    else if (!Loaded)
    {
        <div class="loading"><div class="spinner"></div>読み込み中…</div>
    }
    else
    {
        @* ── 資産構成（クラス別／銘柄別の構成比ドーナツ）── *@
        @if (CompositionData.Count > 0)
        {
            <div class="cat-head" style="margin-top:6px">
                <span>資産構成</span>
                <div class="pf-comp-toggle">
                    <button class="period-btn @(_compMode == "class" ? "active" : "")" @onclick='() => SetCompMode("class")'>クラス別</button>
                    <button class="period-btn @(_compMode == "holding" ? "active" : "")" @onclick='() => SetCompMode("holding")'>銘柄別</button>
                </div>
            </div>
            <div class="graph-card graph-card-full pf-comp-card">
                <div class="spend">
                    <div class="spend-chart">
                        <ApexChart TItem="SpendSlice" Options="CompDonutOptions" @key="@($"comp-{_compMode}-{_compRev}")">
                            <ApexPointSeries TItem="SpendSlice"
                                             Items="CompositionData"
                                             SeriesType="SeriesType.Donut"
                                             Name="資産構成"
                                             XValue="@(e => e.Label)"
                                             YValue="@(e => e.Value)" />
                        </ApexChart>
                    </div>
                    <div class="spend-list">
                        <div class="spend-row spend-head">
                            <span></span><span>@(_compMode == "class" ? "資産クラス" : "銘柄")</span><span>評価額</span><span>割合</span>
                        </div>
                        @foreach (var s in CompositionData)
                        {
                            <div class="spend-row">
                                <span class="color-dot" style="background:@s.Color"></span>
                                <span class="spend-name">@s.Label</span>
                                <span class="spend-amt">¥@s.Value.ToString("#,0")</span>
                                <span class="spend-pct">@CompPct(s.Value)</span>
                            </div>
                        }
                        <div class="spend-row spend-total">
                            <span></span><span>合計</span>
                            <span class="spend-amt">¥@CompTotal.ToString("#,0")</span>
                            <span></span>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* ── 推移（総資産・元本・評価損益）。元本は取引履歴から全期間、総資産/評価損益は価格更新で記録した日以降 ── *@
        @if (CostSeries.Count > 0 || AssetSeries.Count > 0)
        {
            <div class="cat-head" style="margin-top:18px">
                <span>推移</span>
                <div class="pf-trend-period">
                    @foreach (var p in TrendPeriods)
                    {
                        <button class="period-btn @(_trendPeriod == p.Key ? "active" : "")" @onclick="() => SetTrendPeriod(p.Key)">@p.Label</button>
                    }
                </div>
            </div>
            <div class="graph-grid pf-trend-grid">
                <div class="graph-card">
                    <h4>総資産・元本の推移</h4>
                    <ApexChart TItem="ChartPoint" Options="AssetLineOpt" @key="@($"asset-{_trendRev}")">
                        <ApexPointSeries TItem="ChartPoint" Items="CostSeries" SeriesType="SeriesType.Line"
                                         Name="元本" XValue="@(e => (object)e.XDate)" YValue="@(e => e.Value)" />
                        <ApexPointSeries TItem="ChartPoint" Items="AssetSeries" SeriesType="SeriesType.Line"
                                         Name="総資産" XValue="@(e => (object)e.XDate)" YValue="@(e => e.Value)" />
                    </ApexChart>
                </div>
                @if (PnlSeries.Count > 0)
                {
                    <div class="graph-card">
                        <h4>評価損益の推移</h4>
                        <ApexChart TItem="ChartPoint" Options="PnlLineOpt" @key="@($"pnl-{_trendRev}")">
                            <ApexPointSeries TItem="ChartPoint" Items="PnlSeries" SeriesType="SeriesType.Line"
                                             Name="評価損益" XValue="@(e => e.Label)" YValue="@(e => e.Value)" />
                        </ApexChart>
                    </div>
                }
            </div>
            @if (AssetSeries.Count <= 1)
            {
                <div class="pf-hint">元本は取引履歴から全期間表示します。総資産・評価損益は「価格更新」のたびに1日1点が記録され、日を追うごとに伸びていきます。</div>
            }
        }

        <div class="cat-head">
            <span>保有銘柄</span>
            <button class="btn" @onclick="OpenAdd">＋ 追加</button>
        </div>

        @if (!Ordered.Any())
        {
            <div class="none">銘柄が登録されていません。「＋ 追加」から取引を登録してください。</div>
        }
        else
        {
            @foreach (var grp in Groups)
            {
                var items = Ordered.Where(h => h.Class == grp.Class).ToList();
                if (items.Count == 0) continue;
                <div class="pf-group-head">
                    <span>@grp.Label</span>
                    <span class="pf-group-meta">
                        @if (grp.Class == AssetClass.UsStock)
                        {
                            <span class="pf-ccy-toggle" title="評価額・評価損益の表示通貨（元本は買った通貨のまま）">
                                <button class="@(_usCcy == Currency.Jpy ? "on" : "")" @onclick="() => SetUsCcy(Currency.Jpy)">円</button>
                                <button class="@(_usCcy == Currency.Usd ? "on" : "")" @onclick="() => SetUsCcy(Currency.Usd)">ドル</button>
                            </span>
                        }
                        <span class="pf-group-note">@ClassDelayNote(grp.Class)</span>
                    </span>
                </div>
                @if (IsMobile)
                {
                    @foreach (var h in items)
                    {
                        var s = Summary(h);
                        var upnl = UnrealizedPnl(h, s);
                        <div class="list-card-wrap">
                            <button class="list-card" @onclick="() => OpenTx(h.Id)">
                                <div class="list-card-main">
                                    <span class="list-card-name">@DisplayName(h)</span>
                                    <span class="list-card-amount">@MoneyDispOpt(h, ValDisp(h, s.Quantity))</span>
                                </div>
                                <div class="list-card-sub">
                                    <span class="pf-badge">@AccountLabel(h.Account)</span>
                                    <span class="@PnlClass(upnl ?? 0)">@MoneyDispSignedOpt(h, UpnlDisp(h, s))@PnlPct(upnl, s.CostBasis)@if (DayChangePct(h) is decimal dp) {<span class="pf-day @PnlClass(dp)">前日 @MoneyDispSignedOpt(h, DayChangeAmount(h, s.Quantity)) (@DayPct(dp))</span>}</span>
                                </div>
                                <div class="list-card-detail">
                                    <span>現在価格 @CurPriceDisp(h)</span>
                                </div>
                            </button>
                            <div class="list-card-move">
                                <button @onclick="() => MoveHolding(h, -1)" disabled="@(h == items.First())" aria-label="上へ">▲</button>
                                <button @onclick="() => MoveHolding(h, 1)" disabled="@(h == items.Last())" aria-label="下へ">▼</button>
                            </div>
                        </div>
                    }
                }
                else
                {
                <div class="pf-grid pf-grid-head">
                    <span>銘柄名</span>
                    <span class="pf-num">元本</span><span class="pf-num">平均取得単価</span><span class="pf-num">数量</span><span class="pf-num">現在価格</span>
                    <span class="pf-num">評価額／損益</span><span class="pf-num">前日比</span>
                    <span></span><span></span>
                </div>
                @foreach (var h in items)
                {
                    var s = Summary(h);
                    var upnl = UnrealizedPnl(h, s);
                    var day = DayChangePct(h);
                    <div class="pf-grid pf-row @(_dragOverId == h.Id ? "pf-drag-over" : "")"
                         draggable="true" @key="h.Id"
                         @ondragstart="() => _dragId = h.Id"
                         @ondragenter="() => _dragOverId = h.Id"
                         @ondragover:preventDefault="true"
                         @ondragleave="() => OnDragLeave(h.Id)"
                         @ondrop="() => OnDrop(h)"
                         @ondrop:preventDefault="true"
                         @ondragend="OnDragEnd">
                        <span class="pf-hname" title="@DisplayName(h)"><span class="pf-drag-handle" title="ドラッグで並べ替え">⠿</span><span class="pf-hname-body"><span class="pf-hname-name">@DisplayName(h)</span><span class="pf-badge pf-badge-sub">@AccountLabel(h.Account)</span></span></span>
                        <span class="pf-num">@Money(h, s.CostBasis)</span>
                        <span class="pf-num">@Price(h, s.AvgUnitPrice)</span>
                        <span class="pf-num">@Qty(s.Quantity)</span>
                        <span class="pf-num">@CurPriceDisp(h)</span>
                        <span class="pf-num">@MoneyDispOpt(h, ValDisp(h, s.Quantity))<span class="pf-sub-pnl @PnlClass(upnl ?? 0)">@MoneyDispSignedOpt(h, UpnlDisp(h, s))<span class="pf-pnl-pct">@PnlPct(upnl, s.CostBasis)</span></span></span>
                        <span class="pf-num @(day is decimal dc ? PnlClass(dc) : "")">@if (day is decimal dv){@MoneyDispSignedOpt(h, DayChangeAmount(h, s.Quantity))<span class="pf-day">@DayPct(dv)</span>}else{<text>—</text>}</span>
                        <button class="btn-sm" @onclick="() => OpenTx(h.Id)">取引</button>
                        <button class="x" @onclick="() => AskDelete(h)">✕</button>
                    </div>
                }
                }
            }
        }

        <div class="foot" style="text-align:left;margin-top:10px">
            「＋ 追加」で新規銘柄を登録すると保有銘柄として表示されます。同じ銘柄は合算されます。<br />
            各銘柄の「取引」で買付・売却・配当の追加/編集と銘柄設定ができます。投資信託は基準価額＝1万口あたりとして計算します。<br />
            「価格更新」で現在価格と USD/JPY を取得します（日本株＝証券コード4桁／米国株＝ティッカー／投資信託＝協会コード）。コード未設定の投資信託は「取引」で現在基準価額を手入力できます。
        </div>
    }
</div>

@* ── 新規銘柄登録ダイアログ（誤クリック防止のためダイアログ外クリックでは閉じない）── *@
@if (_addOpen)
{
    <div class="dialog-overlay">
        <div class="dialog-box pf-add-box" @onclick:stopPropagation="true">
            <h4>新規銘柄登録</h4>
            <div class="pf-add-form">
                <label>資産クラス
                    <select @bind="_nClass">
                        <option value="@AssetClass.Fund">投資信託</option>
                        <option value="@AssetClass.JpStock">日本株</option>
                        <option value="@AssetClass.UsStock">米国株</option>
                    </select>
                </label>
                <label>口座区分
                    <select @bind="_nAccount">
                        <option value="@AccountKind.NisaGrowth">NISA（成長投資枠）</option>
                        <option value="@AccountKind.NisaTsumitate">NISA（つみたて投資枠）</option>
                        <option value="@AccountKind.Tokutei">特定</option>
                        <option value="@AccountKind.General">一般</option>
                    </select>
                </label>
                @if (_nClass == AssetClass.UsStock)
                {
                    <label>建て通貨
                        <select @bind="_nCurrency">
                            <option value="@Currency.Jpy">円建て</option>
                            <option value="@Currency.Usd">ドル建て</option>
                        </select>
                    </label>
                }

                @if (_nClass == AssetClass.Fund)
                {
                    <label>投信を選択
                        <select @bind="_nFundPick" @bind:after="OnFundPicked">
                            <option value="">― 一覧から選択 ―</option>
                            @foreach (var f in FundMaster.Items)
                            {
                                <option value="@f.Code">@f.Name</option>
                            }
                            <option value="__other">その他（一覧に無い投信）</option>
                        </select>
                    </label>
                    @if (_nFundPick == "__other")
                    {
                        <label>銘柄名
                            <input @bind="_nName" placeholder="例 ○○インデックスファンド" />
                        </label>
                        <label>協会コード
                            <input @bind="_nAssocFundCd" placeholder="例 0331418A" />
                        </label>
                        <span class="pf-hint">協会コード（8桁）を入れると「価格更新」で基準価額を自動取得します。未入力でも現在基準価額は手入力できます。</span>
                    }
                }
                else
                {
                    <label>銘柄名
                        <input @bind="_nName" placeholder="@(_nClass == AssetClass.JpStock ? "例 トヨタ自動車" : "例 アップル")" />
                    </label>
                    @if (_nClass == AssetClass.JpStock)
                    {
                        <label>証券コード（4桁）
                            <input @bind="_nSymbol" placeholder="例 7203 / 9432" />
                        </label>
                    }
                    else
                    {
                        <label>ティッカー
                            <input @bind="_nSymbol" placeholder="例 AAPL / TSM" />
                        </label>
                    }
                }

                <div class="pf-add-buy">
                    <span class="pf-add-buy-title">買付</span>
                    <label>約定日 <input type="date" value="@_bDate" @onchange="e => _bDate = e.Value?.ToString() ?? string.Empty" /></label>
                    <label>数量 <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@_bQty" ValueChanged="v => _bQty = v" /></label>
                    <label>@BuyPriceLabel <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@_bPrice" ValueChanged="v => _bPrice = v" /></label>
                </div>
            </div>
            <div class="dialog-btns">
                <button class="btn" @onclick="CloseAdd">キャンセル</button>
                <button class="btn primary" disabled="@(!CanAdd)" @onclick="SubmitAdd">登録</button>
            </div>
        </div>
    </div>
}

@* ── 取引・設定ダイアログ（既存銘柄。編集はバッファに溜め「保存」で初めて反映・外側クリックでは閉じない）── *@
@if (_txHoldingId != null && _editH != null)
{
    var h = _editH;
    var s = PortfolioMath.Summarize(h, _editBuys, _editSells, _editDivs);
    <div class="dialog-overlay">
        <div class="dialog-box pf-tx-box" @onclick:stopPropagation="true">
            <h4>@DisplayName(h) の取引・設定</h4>

            <div class="pf-tx-settings">
                <label>銘柄名 <input @bind="h.Name" @bind:after="TxDirty" /></label>
                <label>資産クラス
                    <select @bind="h.Class" @bind:after="OnClassChanged">
                        <option value="@AssetClass.Fund">投資信託</option>
                        <option value="@AssetClass.JpStock">日本株</option>
                        <option value="@AssetClass.UsStock">米国株</option>
                    </select>
                </label>
                <label>口座区分
                    <select @bind="h.Account" @bind:after="TxDirty">
                        <option value="@AccountKind.NisaGrowth">NISA（成長投資枠）</option>
                        <option value="@AccountKind.NisaTsumitate">NISA（つみたて投資枠）</option>
                        <option value="@AccountKind.Tokutei">特定</option>
                        <option value="@AccountKind.General">一般</option>
                        @if (h.Account == AccountKind.Nisa)
                        {
                            <option value="@AccountKind.Nisa">NISA（旧・未分類）</option>
                        }
                    </select>
                </label>
                @if (h.Class == AssetClass.UsStock)
                {
                    <label>建て通貨
                        <select @bind="h.CostCurrency" @bind:after="TxDirty">
                            <option value="@Currency.Jpy">円建て</option>
                            <option value="@Currency.Usd">ドル建て</option>
                        </select>
                    </label>
                }
                @if (h.Class == AssetClass.JpStock)
                {
                    <label>証券コード <input @bind="h.Symbol" @bind:after="TxDirty" placeholder="例 7203 / 9432" /></label>
                }
                else if (h.Class == AssetClass.UsStock)
                {
                    <label>ティッカー <input @bind="h.Symbol" @bind:after="TxDirty" placeholder="例 AAPL / TSM" /></label>
                }
                else
                {
                    <label>投信を選択
                        <select value="@h.AssocFundCd" @onchange="e => OnTxFundPicked(e.Value?.ToString())">
                            <option value="">― 一覧から選択 ―</option>
                            @foreach (var f in FundMaster.Items)
                            {
                                <option value="@f.Code">@f.Name</option>
                            }
                        </select>
                    </label>
                    <label>協会コード <input @bind="h.AssocFundCd" @bind:after="TxDirty" placeholder="例 0331418A" /></label>
                }
            </div>

            @if (h.Class == AssetClass.UsStock)
            {
                <div class="pf-hint">米国株の単価は常に「$/株」（ドルで値が付くため）。<b>円で拠出</b>した場合は「取得金額」に拠出した円を入れると、その額が元本（円）になります（為替換算なし）。<b>自分でドル転</b>して買った場合は「ドル建て」にすると元本もドルになります。</div>
            }

            <div class="pf-tx-price">
                <label>@CurPriceLabel(h)
                    <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@_editPrice" ValueChanged="v => { _editPrice = v; TxDirty(); }" />
                </label>
                @if (h.Class == AssetClass.UsStock)
                {
                    <span class="pf-hint">米国株の現在価格は $/株。円換算は USD/JPY @(Store.Data.UsdJpyRate > 0 ? Store.Data.UsdJpyRate.ToString("#,0.##") : "未取得") を使用。</span>
                }
            </div>

            <div class="pf-tx-summary">
                <span>数量 <b>@Qty(s.Quantity)</b></span>
                <span>平均取得単価 <b>@Price(h, s.AvgUnitPrice)</b></span>
                <span>取得原価 <b>@Money(h, s.CostBasis)</b></span>
                <span>評価額 <b>@MoneyOpt(h, EditVal(s.Quantity))</b></span>
                <span>評価損益 <b class="@PnlClass(EditUpnl(s) ?? 0)">@MoneySignedOpt(h, EditUpnl(s))@PnlPct(EditUpnl(s), s.CostBasis)</b></span>
                <span>実現損益 <b class="@PnlClass(s.RealizedPnl)">@MoneySigned(h, s.RealizedPnl)</b></span>
                <span>配当合計 <b>@Money(h, s.Dividends)</b></span>
            </div>

            @* 買付 *@
            <div class="pf-tx-sec">
                <div class="pf-tx-sec-head"><span>買付</span><button class="btn-sm" @onclick="AddBuy">＋ 追加</button></div>
                @if (_editBuys.Count > 0)
                {
                    var fund = h.Class == AssetClass.Fund;              // 投信は取得金額（受渡金額）列
                    var fx = h.CostCurrency == Currency.Usd;            // ドル建てのみ約定為替レート列
                    var espp = ShowEspp(h);                              // TSM かつ社員のみ ESPP 列
                    // 取得金額（拠出した円）列：投信＋円建て株（円で拠出＝為替換算せず元本にする）。ドル建ては約定為替で対応。
                    var amt = fund || (h.Class != AssetClass.Fund && h.CostCurrency == Currency.Jpy);
                    var gridCls = amt && espp ? "pf-tx-grid-espp-amt"
                        : amt ? "pf-tx-grid-amt"
                        : fx && espp ? "pf-tx-grid-fx-espp" : fx ? "pf-tx-grid-fx" : espp ? "pf-tx-grid-espp" : "";
                    @if (!IsMobile)
                    {
                        <div class="pf-tx-grid @gridCls pf-tx-grid-head">
                            <span>約定日</span><span class="pf-num">数量</span><span class="pf-num">@UnitLabel(h)</span>
                            @if (fx) { <span class="pf-num">約定為替</span> }
                            @if (amt) { <span class="pf-num">取得金額(¥)</span> }
                            @if (espp) { <span class="pf-num">ESPP</span> }
                            <span></span>
                        </div>
                    }
                    @foreach (var b in _editBuys.OrderBy(b => b.Date))
                    {
                        @if (IsMobile)
                        {
                            <div class="pf-tx-card" @key="b.Id">
                                @{ var bOpen = _txOpen.Contains(b.Id); }
                                <button type="button" class="pf-tx-cardhead" @onclick="() => ToggleTx(b.Id)">
                                    <span class="pf-tx-sum">@b.Date ・ @Qty(b.Quantity) ・ @Price(h, b.UnitPrice)</span>
                                    <span class="pf-tx-chev">@(bOpen ? "▲" : "▼")</span>
                                </button>
                                @if (bOpen)
                                {
                                <label class="pf-tx-f"><span>約定日</span>
                                    <input type="date" class="pf-tx-date" value="@b.Date" @onchange="e => { b.Date = e.Value?.ToString() ?? string.Empty; TxDirty(); }" />
                                </label>
                                <div class="pf-tx-frow">
                                    <label class="pf-tx-f"><span>数量</span>
                                        <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@b.Quantity" ValueChanged="v => { b.Quantity = v; TxDirty(); }" />
                                    </label>
                                    <label class="pf-tx-f"><span>@UnitLabel(h)</span>
                                        <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@b.UnitPrice" ValueChanged="v => { b.UnitPrice = v; TxDirty(); }" />
                                    </label>
                                </div>
                                @if (fx || amt)
                                {
                                    <div class="pf-tx-frow">
                                        @if (fx)
                                        {
                                            <label class="pf-tx-f"><span>約定為替</span>
                                                <AmountInput CssClass="pf-tx-amt" Decimals="2" Value="@b.FxRate" ValueChanged="v => { b.FxRate = v; TxDirty(); }" />
                                            </label>
                                        }
                                        @if (amt)
                                        {
                                            <label class="pf-tx-f"><span>取得金額(¥)</span>
                                                <AmountInput CssClass="pf-tx-amt" Decimals="0" Value="@b.Amount" ValueChanged="v => { b.Amount = v; TxDirty(); }" />
                                            </label>
                                        }
                                    </div>
                                }
                                @if (espp)
                                {
                                    <label class="pf-tx-f-check">
                                        <input type="checkbox" checked="@b.IsEspp" @onchange="e => { b.IsEspp = (bool)(e.Value ?? false); TxDirty(); }" /> ESPP（会社補助15%を差し引く）
                                    </label>
                                }
                                <button class="btn-sm pf-tx-del" @onclick="() => { _editBuys.Remove(b); TxDirty(); }">この買付を削除</button>
                                }
                            </div>
                        }
                        else
                        {
                        <div class="pf-tx-grid @gridCls" @key="b.Id">
                            <input type="date" class="pf-tx-date" value="@b.Date" @onchange="e => { b.Date = e.Value?.ToString() ?? string.Empty; TxDirty(); }" />
                            <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@b.Quantity" ValueChanged="v => { b.Quantity = v; TxDirty(); }" />
                            <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@b.UnitPrice" ValueChanged="v => { b.UnitPrice = v; TxDirty(); }" />
                            @if (fx)
                            {
                                <AmountInput CssClass="pf-tx-amt" Decimals="2" Value="@b.FxRate" ValueChanged="v => { b.FxRate = v; TxDirty(); }" />
                            }
                            @if (amt)
                            {
                                <AmountInput CssClass="pf-tx-amt" Decimals="0" Value="@b.Amount" ValueChanged="v => { b.Amount = v; TxDirty(); }" />
                            }
                            @if (espp)
                            {
                                <input type="checkbox" class="pf-tx-espp" checked="@b.IsEspp" @onchange="e => { b.IsEspp = (bool)(e.Value ?? false); TxDirty(); }" />
                            }
                            <button class="x" @onclick="() => { _editBuys.Remove(b); TxDirty(); }">✕</button>
                        </div>
                        }
                    }
                    @if (fx)
                    {
                        <div class="pf-hint">「約定為替」に買付時の USD/JPY を入れると、元本（円）が実際の拠出円に一致します。空欄は現在レートで換算します。</div>
                    }
                    @if (espp)
                    {
                        <div class="pf-hint">「ESPP」にチェックした買付は会社補助 @( (PortfolioMath.EsppDiscount * 100).ToString("0") )% を差し引いた実拠出を取得原価とします（個人購入はチェックを外す）。</div>
                    }
                    @if (fund)
                    {
                        <div class="pf-hint">「取得金額」に SBI の受渡金額（実際に支払った円）を入れると、その額をそのまま取得原価にします（空欄は 口数×基準価額÷10,000 で計算するため丸め差が出ます）。</div>
                    }
                    else if (amt)
                    {
                        <div class="pf-hint">円で拠出した銘柄は「取得金額」に実際に支払った円を入れると、その額をそのまま元本にします（為替換算しないのでズレません）。空欄なら 数量×単価 で計算します。</div>
                    }
                }
                else
                {
                    <div class="none">買付の記録はありません。</div>
                }
            </div>

            @* 売却 *@
            <div class="pf-tx-sec">
                <div class="pf-tx-sec-head"><span>売却（解約）</span><button class="btn-sm" @onclick="AddSell">＋ 追加</button></div>
                @if (_editSells.Count > 0)
                {
                    @if (!IsMobile)
                    {
                        <div class="pf-tx-grid pf-tx-grid-head"><span>約定日</span><span class="pf-num">数量</span><span class="pf-num">@UnitLabel(h)</span><span></span></div>
                    }
                    @foreach (var sl in _editSells.OrderBy(s => s.Date))
                    {
                        @if (IsMobile)
                        {
                            <div class="pf-tx-card" @key="sl.Id">
                                @{ var slOpen = _txOpen.Contains(sl.Id); }
                                <button type="button" class="pf-tx-cardhead" @onclick="() => ToggleTx(sl.Id)">
                                    <span class="pf-tx-sum">@sl.Date ・ @Qty(sl.Quantity) ・ @Price(h, sl.UnitPrice)</span>
                                    <span class="pf-tx-chev">@(slOpen ? "▲" : "▼")</span>
                                </button>
                                @if (slOpen)
                                {
                                <label class="pf-tx-f"><span>約定日</span>
                                    <input type="date" class="pf-tx-date" value="@sl.Date" @onchange="e => { sl.Date = e.Value?.ToString() ?? string.Empty; TxDirty(); }" />
                                </label>
                                <div class="pf-tx-frow">
                                    <label class="pf-tx-f"><span>数量</span>
                                        <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@sl.Quantity" ValueChanged="v => { sl.Quantity = v; TxDirty(); }" />
                                    </label>
                                    <label class="pf-tx-f"><span>@UnitLabel(h)</span>
                                        <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@sl.UnitPrice" ValueChanged="v => { sl.UnitPrice = v; TxDirty(); }" />
                                    </label>
                                </div>
                                <button class="btn-sm pf-tx-del" @onclick="() => { _editSells.Remove(sl); TxDirty(); }">この売却を削除</button>
                                }
                            </div>
                        }
                        else
                        {
                        <div class="pf-tx-grid" @key="sl.Id">
                            <input type="date" class="pf-tx-date" value="@sl.Date" @onchange="e => { sl.Date = e.Value?.ToString() ?? string.Empty; TxDirty(); }" />
                            <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@sl.Quantity" ValueChanged="v => { sl.Quantity = v; TxDirty(); }" />
                            <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@sl.UnitPrice" ValueChanged="v => { sl.UnitPrice = v; TxDirty(); }" />
                            <button class="x" @onclick="() => { _editSells.Remove(sl); TxDirty(); }">✕</button>
                        </div>
                        }
                    }
                }
                else
                {
                    <div class="none">売却の記録はありません。</div>
                }
            </div>

            @* 配当（金額＝現金配当・数量＝配当再投資の取得株数で取得コスト$0）*@
            <div class="pf-tx-sec">
                <div class="pf-tx-sec-head"><span>配当・分配金</span><button class="btn-sm" @onclick="AddDiv">＋ 追加</button></div>
                @if (_editDivs.Count > 0)
                {
                    @if (!IsMobile)
                    {
                        <div class="pf-tx-grid pf-tx-grid-head"><span>受取日</span><span class="pf-num">金額</span><span class="pf-num">数量(再投資)</span><span></span></div>
                    }
                    @foreach (var dv in _editDivs.OrderBy(d => d.Date))
                    {
                        @if (IsMobile)
                        {
                            <div class="pf-tx-card" @key="dv.Id">
                                @{ var dvOpen = _txOpen.Contains(dv.Id); }
                                <button type="button" class="pf-tx-cardhead" @onclick="() => ToggleTx(dv.Id)">
                                    <span class="pf-tx-sum">@dv.Date ・ 金額 @Money(h, dv.Amount)@(dv.Quantity != 0 ? $" ・ 再投資 {Qty(dv.Quantity)}" : "")</span>
                                    <span class="pf-tx-chev">@(dvOpen ? "▲" : "▼")</span>
                                </button>
                                @if (dvOpen)
                                {
                                <label class="pf-tx-f"><span>受取日</span>
                                    <input type="date" class="pf-tx-date" value="@dv.Date" @onchange="e => { dv.Date = e.Value?.ToString() ?? string.Empty; TxDirty(); }" />
                                </label>
                                <div class="pf-tx-frow">
                                    <label class="pf-tx-f"><span>金額</span>
                                        <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@dv.Amount" ValueChanged="v => { dv.Amount = v; TxDirty(); }" />
                                    </label>
                                    <label class="pf-tx-f"><span>数量(再投資)</span>
                                        <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@dv.Quantity" ValueChanged="v => { dv.Quantity = v; TxDirty(); }" />
                                    </label>
                                </div>
                                <button class="btn-sm pf-tx-del" @onclick="() => { _editDivs.Remove(dv); TxDirty(); }">この配当を削除</button>
                                }
                            </div>
                        }
                        else
                        {
                        <div class="pf-tx-grid" @key="dv.Id">
                            <input type="date" class="pf-tx-date" value="@dv.Date" @onchange="e => { dv.Date = e.Value?.ToString() ?? string.Empty; TxDirty(); }" />
                            <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@dv.Amount" ValueChanged="v => { dv.Amount = v; TxDirty(); }" />
                            <AmountInput CssClass="pf-tx-amt" Decimals="4" Value="@dv.Quantity" ValueChanged="v => { dv.Quantity = v; TxDirty(); }" />
                            <button class="x" @onclick="() => { _editDivs.Remove(dv); TxDirty(); }">✕</button>
                        </div>
                        }
                    }
                    <div class="pf-hint">配当再投資（現金を受け取らず株式に充当）は「数量」に取得株数だけ入力（取得コスト$0＝平均取得単価が下がる）。通常の現金配当は「金額」のみ入力。</div>
                }
                else
                {
                    <div class="none">配当の記録はありません。</div>
                }
            </div>

            <div class="dialog-btns">
                <button class="btn danger" @onclick="DeleteFromTx">削除</button>
                <button class="btn" style="margin-left:auto" @onclick="RequestCloseTx">閉じる</button>
                <button class="btn primary" @onclick="SaveTx">保存</button>
            </div>
        </div>
    </div>
}

<ConfirmDialog IsVisible="@ShowConfirm"
               Title="銘柄を削除しますか？"
               Message="@ConfirmMessage"
               ConfirmText="削除する"
               OnConfirm="ExecuteDelete"
               OnCancel="() => ShowConfirm = false" />

<ConfirmDialog IsVisible="@_txCloseWarn"
               Title="変更を破棄しますか？"
               Message="@("保存していない変更があります。\n破棄して閉じますか？")"
               ConfirmText="破棄して閉じる"
               OnConfirm="DiscardTx"
               OnCancel="() => _txCloseWarn = false" />
