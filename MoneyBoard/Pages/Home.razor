@page "/"
@implements IDisposable
@using System.Reflection
@inject LedgerService Svc
@inject NavigationManager Nav

<div class="wrap">
    <div class="home-head">
        <div class="app-title">
            MoneyBoard
            @if (!string.IsNullOrEmpty(AppVersion))
            {
                <span class="app-ver">@AppVersion</span>
            }
        </div>
    </div>

    @if (Svc.IsPending)
    {
        <div class="loading">
            <p class="pending-title">アクセス承認待ちです</p>
            <p class="pending-note">オーナーの承認後にご利用いただけます。<br />承認されたら下のボタンで再読み込みしてください。</p>
            <button class="btn" @onclick="Load">再読み込み</button>
        </div>
    }
    else
    {
        @if (ShowConflictNotice)
        {
            <div class="notice">
                <span>別の場所でデータが更新されたため、最新の内容を再読み込みしました。</span>
                <button class="x" @onclick="() => ShowConflictNotice = false">✕</button>
            </div>
        }

        <div class="tabs">
            <button class="tab @(ActiveTab == "monthly" ? "active" : "")" disabled="@TabDisabled" @onclick='() => SetTab("monthly")'>月次管理</button>
            <button class="tab @(ActiveTab == "card" ? "active" : "")" disabled="@TabDisabled" @onclick='() => SetTab("card")'>カード</button>
            <button class="tab @(ActiveTab == "mypage" ? "active" : "")" disabled="@TabDisabled" @onclick='() => SetTab("mypage")'>マイページ</button>
        </div>

        @if (LoadFailed)
        {
            <div class="loading">
                データの読み込みに失敗しました。<br />
                ネットワーク接続を確認して、再度お試しください。<br />
                <button class="btn" @onclick="Load">再読み込み</button>
            </div>
        }
        else if (!Loaded)
        {
            <div class="loading">
                <div class="spinner"></div>
                読み込み中…
            </div>
        }
        else
        {
            @if (ActiveTab == "monthly")  { <MonthlyTab @key="ReloadKey" RequestTab="SetTab" /> }
            @if (ActiveTab == "card")     { <CardTab @key="ReloadKey" /> }
            @if (ActiveTab == "mypage")   { <MyPageTab @key="ReloadKey" /> }
        }
    }
</div>

@code {
    // 下部ナビ（スマホ）からは "/?tab=xxx" で遷移する。クエリでタブを切り替える。
    [Parameter, SupplyParameterFromQuery(Name = "tab")] public string? Tab { get; set; }

    private static readonly string[] ValidTabs = { "monthly", "card", "mypage" };

    private string ActiveTab = "monthly";
    private bool Loaded = false;
    private bool LoadFailed = false;
    private bool ShowConflictNotice = false;
    private string AppVersion = "";

    // 読み込み完了までタブ操作を無効化（空状態のタブを触らせない）
    private bool TabDisabled => !Loaded;
    private int ReloadKey = 0;

    protected override async Task OnInitializedAsync()
    {
        // InformationalVersion は csproj の <Version>（"0.9.0" / SourceLink 併用時は "0.9.0+<sha>"）。
        // ビルドメタ('+'以降)は落として "v0.9.0" の形で表示する。
        var info = typeof(Home).Assembly
            .GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion;
        // "v" を値側に含める（マークアップで v@AppVersion と書くと Razor がメール誤認してリテラル化するため）。
        AppVersion = string.IsNullOrEmpty(info) ? "" : "v" + info.Split('+')[0];
        Svc.StateReloadedExternally += OnExternalReload;
        await Load();
    }

    // 保存競合で最新を読み込み直したとき: タブを再マウントして
    // 子コンポーネントがキャッシュした状態（Mo など）を作り直す。
    private void OnExternalReload()
    {
        ReloadKey++;
        ShowConflictNotice = true;
        InvokeAsync(StateHasChanged);
    }

    // クエリ ?tab= が有効値なら採用（未指定はデスクトップのタブ操作に委ねる）。
    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Tab) && ValidTabs.Contains(Tab))
            ActiveTab = Tab;
    }

    public void Dispose() => Svc.StateReloadedExternally -= OnExternalReload;

    // 読み込み失敗時はタブ内容を描画しない（空状態での編集→実データ上書きを防ぐ）。
    private async Task Load()
    {
        Loaded = false;
        LoadFailed = false;
        if (await Svc.LoadAsync())
            Loaded = true;
        else
            LoadFailed = true;
    }

    // タブ切替は URL(?tab=) 経由に統一（下部バーのハイライトやカード行からの遷移と同期させる）。
    private void SetTab(string tab) => Nav.NavigateTo($"/?tab={tab}");
}
