@page "/"
@implements IDisposable
@inject LedgerService Svc

<div class="wrap">
    <div class="app-title">生計 <small>口座別 引き落とし管理</small></div>

    @if (ShowConflictNotice)
    {
        <div style="background:#fff3cd;border:1px solid #ffe69c;color:#664d03;padding:10px 14px;border-radius:6px;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center;gap:12px">
            <span>別の場所でデータが更新されたため、最新の内容を再読み込みしました。</span>
            <button class="x" @onclick="() => ShowConflictNotice = false">✕</button>
        </div>
    }

    <div class="tabs">
        <button class="tab @(ActiveTab == "monthly" ? "active" : "")" @onclick='() => SetTab("monthly")'>月次管理</button>
        <button class="tab @(ActiveTab == "fixed" ? "active" : "")" @onclick='() => SetTab("fixed")'>固定費設定</button>
        <button class="tab @(ActiveTab == "accounts" ? "active" : "")" @onclick='() => SetTab("accounts")'>口座設定</button>
        <button class="tab @(ActiveTab == "mypage" ? "active" : "")" @onclick='() => SetTab("mypage")'>マイページ</button>
    </div>

    @if (LoadFailed)
    {
        <div class="loading">
            データの読み込みに失敗しました。<br />
            ネットワーク接続を確認して、再度お試しください。<br />
            <button class="btn" style="margin-top:12px" @onclick="Load">再読み込み</button>
        </div>
    }
    else if (!Loaded)
    {
        <div class="loading">読み込み中…</div>
    }
    else
    {
        @if (ActiveTab == "monthly")  { <MonthlyTab @key="ReloadKey" /> }
        @if (ActiveTab == "fixed")    { <FixedCostTab @key="ReloadKey" /> }
        @if (ActiveTab == "accounts") { <AccountsTab @key="ReloadKey" /> }
        @if (ActiveTab == "mypage")   { <MyPageTab @key="ReloadKey" /> }
    }
</div>

@code {
    private string ActiveTab = "monthly";
    private bool Loaded = false;
    private bool LoadFailed = false;
    private bool ShowConflictNotice = false;
    private int ReloadKey = 0;

    protected override async Task OnInitializedAsync()
    {
        Svc.StateReloadedExternally += OnExternalReload;
        await Load();
    }

    // 保存競合で最新を読み込み直したとき: タブを再マウントして
    // 子コンポーネントがキャッシュした状態（Mo など）を作り直す。
    private void OnExternalReload()
    {
        ReloadKey++;
        ShowConflictNotice = true;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Svc.StateReloadedExternally -= OnExternalReload;

    // 読み込み失敗時はタブ内容を描画しない（空状態での編集→実データ上書きを防ぐ）。
    private async Task Load()
    {
        Loaded = false;
        LoadFailed = false;
        if (await Svc.LoadAsync())
            Loaded = true;
        else
            LoadFailed = true;
    }

    private void SetTab(string tab) => ActiveTab = tab;
}
