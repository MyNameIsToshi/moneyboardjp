@page "/"
@inject LedgerService Svc

<div class="wrap">
    <div class="app-title">生計 <small>口座別 引き落とし管理</small></div>

    <div class="tabs">
        <button class="tab @(ActiveTab == "monthly" ? "active" : "")" @onclick='() => SetTab("monthly")'>月次管理</button>
        <button class="tab @(ActiveTab == "fixed" ? "active" : "")" @onclick='() => SetTab("fixed")'>固定費設定</button>
        <button class="tab @(ActiveTab == "accounts" ? "active" : "")" @onclick='() => SetTab("accounts")'>口座設定</button>
        <button class="tab @(ActiveTab == "mypage" ? "active" : "")" @onclick='() => SetTab("mypage")'>マイページ</button>
    </div>

    @if (LoadFailed)
    {
        <div class="loading">
            データの読み込みに失敗しました。<br />
            ネットワーク接続を確認して、再度お試しください。<br />
            <button class="btn" style="margin-top:12px" @onclick="Load">再読み込み</button>
        </div>
    }
    else if (!Loaded)
    {
        <div class="loading">読み込み中…</div>
    }
    else
    {
        @if (ActiveTab == "monthly")  { <MonthlyTab /> }
        @if (ActiveTab == "fixed")    { <FixedCostTab /> }
        @if (ActiveTab == "accounts") { <AccountsTab /> }
        @if (ActiveTab == "mypage")   { <MyPageTab /> }
    }
</div>

@code {
    private string ActiveTab = "monthly";
    private bool Loaded = false;
    private bool LoadFailed = false;

    protected override async Task OnInitializedAsync() => await Load();

    // 読み込み失敗時はタブ内容を描画しない（空状態での編集→実データ上書きを防ぐ）。
    private async Task Load()
    {
        Loaded = false;
        LoadFailed = false;
        if (await Svc.LoadAsync())
            Loaded = true;
        else
            LoadFailed = true;
    }

    private void SetTab(string tab) => ActiveTab = tab;
}
