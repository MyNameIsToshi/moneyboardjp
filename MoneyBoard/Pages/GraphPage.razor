@page "/graph"
@inject LedgerService Svc
@using ApexCharts

<div class="wrap">
    <div class="graph-sticky">
        <div class="graph-header">
            <div class="app-title">統計</div>
            <button class="btn" disabled="@IsLoading" @onclick="GoBack">← 戻る</button>
        </div>

        @if (Loaded)
        {
            <!-- 期間選択 -->
            <div class="period-select">
                @foreach (var p in Periods)
                {
                    <button class="period-btn @(SelectedPeriod == p.Key ? "active" : "")"
                            @onclick="() => SetPeriod(p.Key)">@p.Value</button>
                }
                <button class="period-btn @(SelectedPeriod == "custom" ? "active" : "")"
                        @onclick='() => SetPeriod("custom")'>期間指定</button>
            </div>

            @if (SelectedPeriod == "custom")
            {
                <div class="period-custom">
                    <select @bind="_customStart" @bind:after="OnCustomChanged">
                        @foreach (var ym in AllYmsAsc)
                        {
                            <option value="@ym">@LedgerService.Label(ym)</option>
                        }
                    </select>
                    <span>〜</span>
                    <select @bind="_customEnd" @bind:after="OnCustomChanged">
                        @foreach (var ym in AllYmsAsc)
                        {
                            <option value="@ym">@LedgerService.Label(ym)</option>
                        }
                    </select>
                </div>
            }

            <div class="period-range">対象期間：@RangeLabel</div>
        }
    </div>

    @if (LoadFailed)
    {
        <div class="loading">
            データの読み込みに失敗しました。<br />
            ネットワーク接続を確認して、再度お試しください。<br />
            <button class="btn" style="margin-top:12px" @onclick="Load">再読み込み</button>
        </div>
    }
    else if (!Loaded)
    {
        <div class="loading"><div class="spinner"></div>読み込み中…</div>
    }
    else
    {
    <div class="graph-grid">

        <!-- ① 月別支出合計推移 -->
        <div class="graph-card">
            <h4>月別 支出合計推移</h4>
            @if (MonthlyDebitData.Any())
            {
                <ApexChart TItem="ChartPoint" Options="DebitLineOptions">
                    <ApexPointSeries TItem="ChartPoint"
                                     Items="MonthlyDebitData"
                                     SeriesType="SeriesType.Line"
                                     Name="支出合計"
                                     XValue="@(e => e.Label)"
                                     YValue="@(e => e.Value)" />
                </ApexChart>
            }
            else { <div class="graph-placeholder">データなし</div> }
        </div>

        <!-- ② 口座別月末残高推移 -->
        <div class="graph-card">
            <h4>口座別 月末残高推移</h4>
            @if (BalanceSeriesData.Any())
            {
                <ApexChart TItem="ChartPoint" Options="BalanceLineOptions">
                    @foreach (var series in BalanceSeriesData)
                    {
                        <ApexPointSeries TItem="ChartPoint"
                                         Items="series.Value"
                                         SeriesType="SeriesType.Line"
                                         Name="@series.Key"
                                         XValue="@(e => e.Label)"
                                         YValue="@(e => e.Value)" />
                    }
                </ApexChart>
            }
            else { <div class="graph-placeholder">データなし</div> }
        </div>

        <!-- ③ 収入の内訳推移（給料・ボーナス・臨時収入を入力名ごとに積み上げ） -->
        <div class="graph-card">
            <h4>収入の内訳推移</h4>
            @if (IncomeBreakdown.Any())
            {
                <ApexChart TItem="ChartPoint" Options="IncomeBreakdownOptions" @key="@($"inc-{SelectedPeriod}")">
                    @foreach (var s in IncomeBreakdown)
                    {
                        <ApexPointSeries TItem="ChartPoint"
                                         Items="s.Data"
                                         SeriesType="SeriesType.Bar"
                                         Name="@s.Name"
                                         XValue="@(e => e.Label)"
                                         YValue="@(e => e.Value)" />
                    }
                </ApexChart>
            }
            else { <div class="graph-placeholder">データなし</div> }
        </div>

        <!-- ④ 収入 vs 支出 -->
        <div class="graph-card">
            <h4>収入 vs 支出比較</h4>
            @if (IncomeData.Any())
            {
                <ApexChart TItem="ChartPoint" Options="IncomeBarOptions"
                           OnDataPointSelection="OnIncomeVsExpenseSelected">
                    <ApexPointSeries TItem="ChartPoint"
                                     Items="IncomeData"
                                     SeriesType="SeriesType.Bar"
                                     Name="収入"
                                     XValue="@(e => e.Label)"
                                     YValue="@(e => e.Value)" />
                    <ApexPointSeries TItem="ChartPoint"
                                     Items="MonthlyDebitData"
                                     SeriesType="SeriesType.Bar"
                                     Name="支出"
                                     XValue="@(e => e.Label)"
                                     YValue="@(e => e.Value)" />
                </ApexChart>
            }
            else { <div class="graph-placeholder">データなし</div> }
        </div>

        <!-- ⑤ 月別 固定費合計推移 -->
        <div class="graph-card">
            <h4>月別 固定費合計推移</h4>
            @if (FixedCostData.Any())
            {
                <ApexChart TItem="ChartPoint" Options="FixedBarOptions"
                           OnDataPointSelection="OnFixedSelected">
                    <ApexPointSeries TItem="ChartPoint"
                                     Items="FixedCostData"
                                     SeriesType="SeriesType.Bar"
                                     Name="固定費合計"
                                     XValue="@(e => e.Label)"
                                     YValue="@(e => e.Value)" />
                </ApexChart>
            }
            else { <div class="graph-placeholder">データなし</div> }
        </div>

        <!-- ⑥ カテゴリ別支出（カード明細） -->
        <div class="graph-card graph-card-full">
            <h4>カテゴリ別 支出（カード明細）</h4>
            @if (CategorySpendData.Any())
            {
                <div class="spend">
                    <div class="spend-chart">
                        <ApexChart TItem="CategorySlice" Options="DonutOptions" @key="@($"cat-{SelectedPeriod}")"
                                   OnDataPointSelection="OnSliceSelected">
                            <ApexPointSeries TItem="CategorySlice"
                                             Items="CategorySpendData"
                                             SeriesType="SeriesType.Donut"
                                             Name="支出"
                                             XValue="@(e => e.Label)"
                                             YValue="@(e => e.Value)" />
                        </ApexChart>
                    </div>
                    <div class="spend-list">
                        <div class="spend-row spend-head">
                            <span></span><span>カテゴリ</span><span>金額</span><span>割合</span><span>件数</span>
                        </div>
                        @foreach (var s in CategorySpendData)
                        {
                            <div class="spend-row spend-row-click" @onclick="() => OpenCatDetail(s.Key)" title="明細を表示">
                                <span class="color-dot" style="background:@s.Color"></span>
                                <span class="spend-name">@s.Label</span>
                                <span class="spend-amt">@Yen(s.Value)</span>
                                <span class="spend-pct">@Pct(s.Value)</span>
                                <span class="spend-cnt">@s.Count 件 <span class="spend-chevron">›</span></span>
                            </div>
                        }
                        <div class="spend-row spend-total">
                            <span></span><span>合計</span>
                            <span class="spend-amt">@Yen(CategoryTotal)</span>
                            <span></span>
                            <span class="spend-cnt">@CategorySpendData.Sum(s => s.Count) 件</span>
                        </div>
                    </div>
                </div>
            }
            else { <div class="graph-placeholder">カード明細がありません</div> }
        </div>

        <!-- ⑦ カード別利用額（カード明細） -->
        <div class="graph-card graph-card-full">
            <h4>カード別 利用額</h4>
            @if (CardSpendData.Any())
            {
                <div class="spend">
                    <div class="spend-chart">
                        <ApexChart TItem="CardSlice" Options="CardDonutOptions" @key="@($"card-{SelectedPeriod}")"
                                   OnDataPointSelection="OnCardSliceSelected">
                            <ApexPointSeries TItem="CardSlice"
                                             Items="CardSpendData"
                                             SeriesType="SeriesType.Donut"
                                             Name="利用額"
                                             XValue="@(e => e.Label)"
                                             YValue="@(e => e.Value)" />
                        </ApexChart>
                    </div>
                    <div class="spend-list">
                        <div class="spend-row spend-head">
                            <span></span><span>カード</span><span>金額</span><span>割合</span><span>件数</span>
                        </div>
                        @foreach (var s in CardSpendData)
                        {
                            <div class="spend-row spend-row-click" @onclick="() => OpenCardDetail(s.Key)" title="明細を表示">
                                <span class="color-dot" style="background:@s.Color"></span>
                                <span class="spend-name">@s.Label</span>
                                <span class="spend-amt">@Yen(s.Value)</span>
                                <span class="spend-pct">@PctOf(s.Value, CardTotal)</span>
                                <span class="spend-cnt">@s.Count 件 <span class="spend-chevron">›</span></span>
                            </div>
                        }
                        <div class="spend-row spend-total">
                            <span></span><span>合計</span>
                            <span class="spend-amt">@Yen(CardTotal)</span>
                            <span></span>
                            <span class="spend-cnt">@CardSpendData.Sum(s => s.Count) 件</span>
                        </div>
                    </div>
                </div>
            }
            else { <div class="graph-placeholder">カード明細がありません</div> }
        </div>

    </div>
    }

    @if (_detail is not null)
    {
        <div class="dialog-overlay" @onclick="CloseDetail">
            <div class="dialog-box cat-detail-box" @onclick:stopPropagation="true">
                <div class="cat-detail-head">
                    <span class="color-dot" style="background:@_detail.Color"></span>
                    <h4>@_detail.Title の明細</h4>
                    <button class="x" @onclick="CloseDetail">✕</button>
                </div>
                <div class="cat-detail-sub">
                    @RangeLabel ・ @_detail.Count 件 ・ 合計 @Yen(_detail.Total)
                </div>
                <div class="cat-detail-list">
                    @foreach (var r in _detail.Rows)
                    {
                        <div class="spend-detail-row">
                            <span class="sd-date">@FmtDate(r.Date)</span>
                            <span class="sd-name" title="@r.Store">@r.Store</span>
                            <span class="sd-card">@r.Sub</span>
                            <span class="sd-amt">@Yen(r.Amount)</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (_breakdown is not null)
    {
        <div class="dialog-overlay" @onclick="CloseBreakdown">
            <div class="dialog-box cat-detail-box" @onclick:stopPropagation="true">
                <div class="cat-detail-head">
                    <h4>@_breakdown.Title</h4>
                    <button class="x" @onclick="CloseBreakdown">✕</button>
                </div>
                <div class="cat-detail-sub">@RangeLabel ・ 合計 @Yen(_breakdown.Total)</div>
                <div class="cat-detail-list">
                    @foreach (var it in _breakdown.Items)
                    {
                        <div class="breakdown-row">
                            <span class="bd-name" title="@it.Name">@it.Name</span>
                            <span class="bd-amt">@Yen(it.Amount)</span>
                            <span class="bd-pct">@PctOf(it.Amount, _breakdown.Total)</span>
                        </div>
                    }
                    <div class="breakdown-row breakdown-total">
                        <span class="bd-name">合計</span>
                        <span class="bd-amt">@Yen(_breakdown.Total)</span>
                        <span></span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Inject] NavigationManager Nav { get; set; } = default!;

    private string SelectedPeriod = "3";
    private Dictionary<string, string> Periods = new()
    {
        { "3", "3ヶ月" }, { "6", "6ヶ月" }, { "12", "12ヶ月" }, { "all", "全期間" }
    };

    private List<ChartPoint> MonthlyDebitData = new();
    private Dictionary<string, List<ChartPoint>> BalanceSeriesData = new();
    private List<ChartPoint> SalaryData = new();
    private List<ChartPoint> BonusData = new();
    private List<ChartPoint> IncomeData = new();
    private List<ChartPoint> FixedCostData = new();

    // ③ 収入の内訳系列（給料・ボーナス・各臨時収入名）。積み上げ棒で表示。
    private List<IncomeSeries> IncomeBreakdown = new();
    private record IncomeSeries(string Name, List<ChartPoint> Data);

    // ApexChartOptions はチャート固有の状態を書き込むため、1インスタンスを複数の
    // <ApexChart> で共有すると最初の1つしか描画されない。チャートごとに専用インスタンスを持つ。
    private static ApexChartOptions<ChartPoint> NewLineOptions() => new()
    {
        Chart = new Chart { Height = 200, Toolbar = new Toolbar { Show = false } },
        Stroke = new Stroke { Curve = Curve.Smooth },
        Yaxis = new List<YAxis> { new YAxis { Labels = new YAxisLabels { Formatter = "function(v){return '¥'+v.toLocaleString()}" } } }
    };

    private static ApexChartOptions<ChartPoint> NewBarOptions(bool stacked = false) => new()
    {
        Chart = new Chart { Height = 200, Stacked = stacked, Toolbar = new Toolbar { Show = false } },
        Yaxis = new List<YAxis> { new YAxis { Labels = new YAxisLabels { Formatter = "function(v){return '¥'+v.toLocaleString()}" } } }
    };

    private readonly ApexChartOptions<ChartPoint> DebitLineOptions = NewLineOptions();
    private readonly ApexChartOptions<ChartPoint> BalanceLineOptions = NewLineOptions();
    private readonly ApexChartOptions<ChartPoint> IncomeBreakdownOptions = NewBarOptions(stacked: true);
    private readonly ApexChartOptions<ChartPoint> IncomeBarOptions = NewBarOptions();
    private readonly ApexChartOptions<ChartPoint> FixedBarOptions = NewBarOptions();

    private List<CategorySlice> CategorySpendData = new();
    private decimal CategoryTotal => CategorySpendData.Sum(s => s.Value);

    // ドリルダウン（カテゴリ別／カード別 共通モーダル）。明細は日付降順で保持する。
    private Dictionary<string, List<DetailRow>> CategoryDetails = new();   // カテゴリキー → 明細（3列目=カード名）
    private Dictionary<string, List<DetailRow>> CardDetails = new();       // カードキー   → 明細（3列目=カテゴリ名）
    private DetailModal? _detail;   // 開いているモーダル（null=閉）

    private void OpenCatDetail(string key)
    {
        var s = CategorySpendData.FirstOrDefault(x => x.Key == key);
        if (s != null) _detail = new(s.Label, s.Color, s.Count, s.Value, CategoryDetails.GetValueOrDefault(key) ?? new());
    }
    private void OpenCardDetail(string key)
    {
        var s = CardSpendData.FirstOrDefault(x => x.Key == key);
        if (s != null) _detail = new(s.Label, s.Color, s.Count, s.Value, CardDetails.GetValueOrDefault(key) ?? new());
    }
    private void CloseDetail() => _detail = null;

    // ドーナツのスライス選択でも同じモーダルを開く（スライス順=各 SpendData 順）
    private void OnSliceSelected(SelectedData<CategorySlice> sel)
    {
        if (sel.DataPointIndex >= 0 && sel.DataPointIndex < CategorySpendData.Count)
            OpenCatDetail(CategorySpendData[sel.DataPointIndex].Key);
    }
    private void OnCardSliceSelected(SelectedData<CardSlice> sel)
    {
        if (sel.DataPointIndex >= 0 && sel.DataPointIndex < CardSpendData.Count)
            OpenCardDetail(CardSpendData[sel.DataPointIndex].Key);
    }

    public record DetailRow(string Date, string Store, string Sub, decimal Amount);
    public record DetailModal(string Title, string Color, int Count, decimal Total, List<DetailRow> Rows);

    // ── 収入/支出の項目別内訳モーダル（③・④から起動。期間合計で集計）──
    public record BreakdownItem(string Name, decimal Amount);
    public record BreakdownModal(string Title, decimal Total, List<BreakdownItem> Items);
    private BreakdownModal? _breakdown;
    private void CloseBreakdown() => _breakdown = null;

    // ④の収入棒→収入内訳、支出棒→支出内訳（系列0=収入, 1=支出）
    private void OnIncomeVsExpenseSelected(SelectedData<ChartPoint> sel)
    {
        if (sel.SeriesIndex == 0) OpenIncomeBreakdown();
        else OpenExpenseBreakdown();
    }
    // ⑤固定費年間合計→固定費の項目別内訳
    private void OnFixedSelected(SelectedData<ChartPoint> sel) => OpenFixedBreakdown();

    // 対象期間の収入を項目（給料/ボーナス/各臨時収入名）で合算
    private void OpenIncomeBreakdown()
    {
        var yms = GetTargetYms();
        var items = new List<BreakdownItem>
        {
            new("給料", yms.Sum(ym => MonthSum(ym, l => l.Salary))),
            new("ボーナス", yms.Sum(ym => MonthSum(ym, l => l.Bonus))),
        };
        items.AddRange(yms
            .SelectMany(ym => Svc.State.Months.GetValueOrDefault(ym)?.Ledgers.Values ?? Enumerable.Empty<Ledger>())
            .SelectMany(l => l.Incomes)
            .GroupBy(IncomeName)
            .Select(g => new BreakdownItem(g.Key, g.Sum(i => i.Amount))));

        items = items.Where(x => x.Amount != 0).OrderByDescending(x => x.Amount).ToList();
        _breakdown = new("収入の内訳", items.Sum(x => x.Amount), items);
    }

    // 対象期間の支出を項目（月次の Debit 名。カードはカード名で1項目・ATMは対象外）で合算
    private void OpenExpenseBreakdown()
    {
        var yms = GetTargetYms();
        var items = yms
            .SelectMany(ym => Svc.State.Months.GetValueOrDefault(ym)?.Ledgers.Values ?? Enumerable.Empty<Ledger>())
            .SelectMany(l => l.Debits)
            .GroupBy(d => string.IsNullOrWhiteSpace(d.Name) ? "（名称なし）" : d.Name)
            .Select(g => new BreakdownItem(g.Key, g.Sum(d => d.Amount)))
            .Where(x => x.Amount != 0)
            .OrderByDescending(x => x.Amount)
            .ToList();
        _breakdown = new("支出の内訳", items.Sum(x => x.Amount), items);
    }

    // 対象期間の固定費を項目（固定費マスタ）ごとに合算（各月の有効分・ボーナス払い込み）
    private void OpenFixedBreakdown()
    {
        var yms = GetTargetYms();
        var byId = new Dictionary<string, (string Name, decimal Amount)>();
        foreach (var ym in yms)
        {
            var month = Ym.Parse(ym).Month;
            foreach (var fc in Svc.State.FixedCosts.Where(fc => LedgerService.IsFixedCostActive(fc, ym)))
            {
                var cur = byId.GetValueOrDefault(fc.Id);
                byId[fc.Id] = (fc.Name, cur.Amount + LedgerService.GetFixedCostAmount(fc, month));
            }
        }
        var items = byId.Values
            .Select(v => new BreakdownItem(v.Name, v.Amount))
            .Where(x => x.Amount != 0)
            .OrderByDescending(x => x.Amount)
            .ToList();
        _breakdown = new("固定費の内訳", items.Sum(x => x.Amount), items);
    }

    private List<CardSlice> CardSpendData = new();
    private decimal CardTotal => CardSpendData.Sum(s => s.Value);

    // カードは色設定を持たないため、表示順に割り当てる固定パレット。
    private static readonly string[] CardPalette =
    {
        "#5b8def", "#34c3a3", "#f6a609", "#ef6a6a", "#9b7ede",
        "#4db3d6", "#e879b9", "#7ac74f", "#f08a4b", "#6c7a89"
    };

    // ドーナツ共通設定（カテゴリ/カードで別インスタンスにする。1インスタンスを
    // 複数の <ApexChart> で共有すると最初の1つしか描画されないため）。
    private static ApexChartOptions<T> NewDonutOptions<T>() where T : class => new()
    {
        Chart = new Chart { Height = 300, Toolbar = new Toolbar { Show = false } },
        Legend = new Legend { Position = LegendPosition.Bottom },
        Tooltip = new Tooltip { Y = new TooltipY { Formatter = "function(v){return '¥'+v.toLocaleString()}" } },
        // 既定のホバー効果(lighten)だと薄い色(未分類のグレー)が白飛びするため、わずかに暗くする
        States = new States
        {
            Hover = new StatesHover { Filter = new StatesFilter { Type = StatesFilterType.darken, Value = 0.12 } },
            Active = new StatesActive { Filter = new StatesFilter { Type = StatesFilterType.darken, Value = 0.12 } }
        }
    };

    private readonly ApexChartOptions<CategorySlice> DonutOptions = NewDonutOptions<CategorySlice>();
    private readonly ApexChartOptions<CardSlice> CardDonutOptions = NewDonutOptions<CardSlice>();

    // 読み込み完了まで操作不可（/graph を直接リロードしたケースに対応）
    private bool Loaded;
    private bool LoadFailed;
    private bool IsLoading => !Loaded && !LoadFailed;   // 読込中は戻るも無効（失敗時は戻れる）

    // 期間指定（月単位）の開始・終了 ym
    private string _customStart = "";
    private string _customEnd = "";

    private List<string> AllYmsAsc => Svc.State.Months.Keys.OrderBy(x => x).ToList();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        Loaded = false;
        LoadFailed = false;
        // State はアプリ起動時(Home)にメモリへ読込済み。未ロード（直接リロード等）のときだけ取得。
        if (Svc.IsLoaded || await Svc.LoadAsync())
            Loaded = true;
        else
        {
            LoadFailed = true;
            return;
        }
        BuildChartData();
    }

    private void SetPeriod(string p)
    {
        SelectedPeriod = p;
        _detail = null;
        _breakdown = null;
        // 期間指定に切替時、未設定なら全期間の端を初期値にする
        if (p == "custom" && string.IsNullOrEmpty(_customStart))
        {
            var yms = AllYmsAsc;
            if (yms.Count > 0) { _customStart = yms.First(); _customEnd = yms.Last(); }
        }
        BuildChartData();
    }

    private void OnCustomChanged() { _detail = null; _breakdown = null; BuildChartData(); }

    private void GoBack() => Nav.NavigateTo("/");

    private List<string> GetTargetYms()
    {
        var allYms = AllYmsAsc;
        if (SelectedPeriod == "all") return allYms;
        if (SelectedPeriod == "custom")
        {
            var (s, e) = (_customStart, _customEnd);
            if (string.Compare(s, e) > 0) (s, e) = (e, s);   // 逆指定の保険
            return allYms.Where(ym => string.Compare(ym, s) >= 0 && string.Compare(ym, e) <= 0).ToList();
        }
        int count = int.Parse(SelectedPeriod);
        return allYms.TakeLast(count).ToList();
    }

    // 現在の対象期間を実際の月で明記する（例: 2026年3月 〜 2026年6月（4ヶ月））
    private string RangeLabel
    {
        get
        {
            var yms = GetTargetYms();
            if (yms.Count == 0) return "対象データなし";
            var first = LedgerService.Label(yms.First());
            var last = LedgerService.Label(yms.Last());
            return first == last ? $"{first}（1ヶ月）" : $"{first} 〜 {last}（{yms.Count}ヶ月）";
        }
    }

    private void BuildChartData()
    {
        var yms = GetTargetYms();

        // 支出合計は Debits のみ（ATM出金は AtmWithdraw フィールドで別管理＝統計から自動除外）
        MonthlyDebitData = BuildSeries(yms, ym => MonthSum(ym, l => l.Debits.Sum(d => d.Amount)));
        SalaryData       = BuildSeries(yms, ym => MonthSum(ym, l => l.Salary));
        BonusData        = BuildSeries(yms, ym => MonthSum(ym, l => l.Bonus));
        // ④ 収入総額は給料＋ボーナス＋臨時収入（ATM入金は資産移動のため含めない）
        IncomeData       = BuildSeries(yms, ym => MonthSum(ym, l => l.Salary + l.Bonus + l.Incomes.Sum(i => i.Amount)));
        BuildIncomeBreakdown(yms);

        BalanceSeriesData = Svc.ActiveAccounts.ToDictionary(
            a => a.Name,
            a => BuildSeries(yms, ym => Svc.CloseOf(ym, a.Id)));

        FixedCostData = BuildSeries(yms, ym =>
        {
            var month = Ym.Parse(ym).Month;
            return Svc.State.FixedCosts
                .Where(fc => LedgerService.IsFixedCostActive(fc, ym))
                .Sum(fc => LedgerService.GetFixedCostAmount(fc, month));
        });

        BuildCategorySpend(yms);
        BuildCardSpend(yms);
    }

    // 期間中の全カード明細を CategoryId で集計（未分類はまとめて末尾の色なし扱い）
    private void BuildCategorySpend(List<string> yms)
    {
        // 月をまたいで明細を集める（ドリルダウン表示用に日付降順で保持）
        var details = yms
            .SelectMany(ym => Svc.State.Months.GetValueOrDefault(ym)?.CardDetails ?? Enumerable.Empty<CardDetail>())
            .ToList();

        var groups = details.GroupBy(d => d.CategoryId ?? "").ToList();

        CategorySpendData = groups
            .Select(g =>
            {
                var cat = Svc.CategoryById(g.Key);
                return new CategorySlice
                {
                    Key = g.Key,
                    Label = cat?.Name ?? "未分類",
                    Value = g.Sum(d => d.Amount),
                    Color = cat?.Color ?? "#bdbdbd",
                    Count = g.Count()
                };
            })
            .OrderByDescending(s => s.Value)
            .ToList();

        // ドリルダウン用：カテゴリごとの明細（日付降順）
        CategoryDetails = groups.ToDictionary(
            g => g.Key,
            g => g.OrderByDescending(d => d.Date)
                  .Select(d => new DetailRow(d.Date, d.Name, Svc.CardById(d.CardId)?.Name ?? "", d.Amount))
                  .ToList());

        // スライス色をカテゴリ設定色に合わせる（データ並びと同順）
        DonutOptions.Colors = CategorySpendData.Select(s => s.Color).ToList();
    }

    // 期間中の全カード明細を CardId で集計。削除済みカードもソフト削除でレコードが
    // 残るため名前を引けて、自身のスライスとして表示される。
    private void BuildCardSpend(List<string> yms)
    {
        var details = yms
            .SelectMany(ym => Svc.State.Months.GetValueOrDefault(ym)?.CardDetails ?? Enumerable.Empty<CardDetail>())
            .ToList();

        var groups = details.GroupBy(d => d.CardId ?? "").ToList();

        CardSpendData = groups
            .Select(g => new CardSlice
            {
                Key = g.Key,
                Label = Svc.CardById(g.Key)?.Name is { Length: > 0 } n ? n : "（不明）",
                Value = g.Sum(d => d.Amount),
                Count = g.Count()
            })
            .OrderByDescending(s => s.Value)
            .ToList();

        // ドリルダウン用：カードごとの明細（日付降順・3列目はカテゴリ名）
        CardDetails = groups.ToDictionary(
            g => g.Key,
            g => g.OrderByDescending(d => d.Date)
                  .Select(d => new DetailRow(d.Date, d.Name, Svc.CategoryById(d.CategoryId)?.Name ?? "未分類", d.Amount))
                  .ToList());

        // 表示順にパレット色を割り当て、スライス色と一覧ドットを揃える。
        for (int i = 0; i < CardSpendData.Count; i++)
            CardSpendData[i].Color = CardPalette[i % CardPalette.Length];
        CardDonutOptions.Colors = CardSpendData.Select(s => s.Color).ToList();
    }

    // ③ 給料・ボーナスに加え、期間中に登場する臨時収入を入力名ごとの系列にする。
    private void BuildIncomeBreakdown(List<string> yms)
    {
        var series = new List<IncomeSeries>
        {
            new("給料", SalaryData),
            new("ボーナス", BonusData),
        };

        // 期間中の臨時収入の入力名（空名は「その他収入」にまとめる）を出現順で収集
        var names = yms
            .SelectMany(ym => Svc.State.Months.GetValueOrDefault(ym)?.Ledgers.Values ?? Enumerable.Empty<Ledger>())
            .SelectMany(l => l.Incomes)
            .Select(IncomeName)
            .Distinct()
            .ToList();

        foreach (var name in names)
        {
            series.Add(new(name, BuildSeries(yms, ym =>
                MonthSum(ym, l => l.Incomes.Where(i => IncomeName(i) == name).Sum(i => i.Amount)))));
        }

        // すべて 0 の系列しかない（=収入が一切ない）場合は空にしてプレースホルダ表示
        IncomeBreakdown = series.Any(s => s.Data.Any(p => p.Value != 0)) ? series : new();
    }

    private static string IncomeName(IncomeItem i) => string.IsNullOrWhiteSpace(i.Name) ? "その他収入" : i.Name;

    private static string Yen(decimal v) => "¥" + v.ToString("#,0");
    // "yyyy-MM-dd" → "M/d"（不正な値はそのまま返す）
    private static string FmtDate(string d) =>
        DateTime.TryParse(d, out var dt) ? dt.ToString("M/d") : d;
    private string Pct(decimal v) => PctOf(v, CategoryTotal);
    private static string PctOf(decimal v, decimal total) => total == 0 ? "0%" : (v / total * 100).ToString("0.0") + "%";

    // 期間中の各月について Label/Value のチャート点を作る共通処理
    private static List<ChartPoint> BuildSeries(List<string> yms, Func<string, decimal> valueOf) =>
        yms.Select(ym => new ChartPoint { Label = LedgerService.Label(ym), Value = valueOf(ym) }).ToList();

    // 指定月の全口座台帳にセレクタを適用して合計（月が無ければ 0）
    private decimal MonthSum(string ym, Func<Ledger, decimal> selector) =>
        Svc.State.Months.GetValueOrDefault(ym)?.Ledgers.Values.Sum(selector) ?? 0;

    public class ChartPoint
    {
        public string Label { get; set; } = "";
        public decimal Value { get; set; }
    }

    public class CategorySlice
    {
        public string Key { get; set; } = "";   // CategoryId（未分類は ""）
        public string Label { get; set; } = "";
        public decimal Value { get; set; }
        public string Color { get; set; } = "";
        public int Count { get; set; }
    }

    public class CardSlice
    {
        public string Key { get; set; } = "";   // CardId（不明は ""）
        public string Label { get; set; } = "";
        public decimal Value { get; set; }
        public string Color { get; set; } = "";
        public int Count { get; set; }
    }
}
