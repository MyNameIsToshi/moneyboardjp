@page "/graph"
@inject LedgerService Svc
@using ApexCharts

<div class="wrap">
    <div class="graph-sticky">
        <div class="graph-header">
            <AppTitle Subtitle="統計" />
        </div>
        @* PC用の共通ページヘッダー（スマホは非表示。サイドナビと同じ字形・画面名） *@
        <PageHeader Icon="bar_chart" Title="統計" Subtitle="収支・カテゴリ" />

        @if (Loaded)
        {
            <!-- 期間選択 -->
            <div class="period-select">
                @foreach (var p in Periods)
                {
                    <button class="period-btn @(SelectedPeriod == p.Key ? "active" : "")"
                            @onclick="() => SetPeriod(p.Key)">@p.Value</button>
                }
                <button class="period-btn @(SelectedPeriod == "custom" ? "active" : "")"
                        @onclick='() => SetPeriod("custom")'>期間指定</button>
            </div>

            @if (SelectedPeriod == "custom")
            {
                <div class="period-custom">
                    <select @bind="_customStart" @bind:after="OnCustomChanged">
                        @foreach (var ym in AllYmsAsc)
                        {
                            <option value="@ym">@LedgerService.Label(ym)</option>
                        }
                    </select>
                    <span>〜</span>
                    <select @bind="_customEnd" @bind:after="OnCustomChanged">
                        @foreach (var ym in AllYmsAsc)
                        {
                            <option value="@ym">@LedgerService.Label(ym)</option>
                        }
                    </select>
                </div>
            }

            <div class="period-range">対象期間：@RangeLabel</div>
        }
    </div>

    @if (LoadFailed)
    {
        <div class="loading">
            データの読み込みに失敗しました。<br />
            ネットワーク接続を確認して、再度お試しください。<br />
            <button class="btn" style="margin-top:12px" @onclick="Load">再読み込み</button>
        </div>
    }
    else if (!Loaded)
    {
        <div class="loading"><div class="spinner"></div>読み込み中…</div>
    }
    else
    {
    <div class="graph-grid">

        <!-- 要約バンド：期間収支ヒーロー＋指標4枚（収入/支出/固定費/貯蓄率） -->
        <div class="stat-band">
            <div class="stat hero">
                <div class="hero-lab">
                    期間収支（収入 − 支出）
                    <span class="hero-pill @(IsSurplus ? "surplus" : "deficit")">
                        <span class="msym">@(IsSurplus ? "trending_up" : "trending_down")</span>@(IsSurplus ? "黒字" : "赤字")
                    </span>
                </div>
                <div class="hero-val">@MaskedSignedYen(IsMasked, NetTotal)</div>
                <div class="hero-sub">@RangeLabel 累計　収入 @MaskedYen(IsMasked, IncomeTotal) − 支出 @MaskedYen(IsMasked, ExpenseTotal)</div>
            </div>

            <div class="stat-metrics">
                <button type="button" class="stat stat-click" @onclick="OpenIncomeBreakdown">
                    <div class="lab">収入 合計</div>
                    <div class="val ok">@MaskedYen(IsMasked, IncomeTotal)</div>
                </button>
                <button type="button" class="stat stat-click" @onclick="OpenExpenseBreakdown">
                    <div class="lab">支出 合計</div>
                    <div class="val">@MaskedYen(IsMasked, ExpenseTotal)</div>
                </button>
                <button type="button" class="stat stat-click" @onclick="OpenFixedBreakdown">
                    <div class="lab">固定費 合計</div>
                    <div class="val">@MaskedYen(IsMasked, FixedTotal)</div>
                    <div class="stat-note">支出の約@(FixedPctOfExpense)%</div>
                </button>
                <div class="stat">
                    <div class="lab">貯蓄率</div>
                    <div class="val accent">@(SavingsRate is { } r ? (r * 100).ToString("0.0") + "%" : "—")</div>
                    <div class="stat-note">収入に対する収支</div>
                </div>
            </div>
        </div>

        <!-- メイン：収入 vs 支出 推移（収入・支出=棒／収支=折れ線） -->
        <div class="graph-card graph-card-full">
            <div class="graph-card-head">
                <h4>収入 vs 支出 推移</h4>
                <span class="graph-card-hint">棒＝収入・支出　/　線＝収支　・　棒タップで内訳</span>
            </div>
            @if (IncomeData.Any())
            {
                <ApexChart TItem="ChartPoint" Options="ComboOptions" @key="@($"combo-{SelectedPeriod}-{_maskRev}")"
                           OnDataPointSelection="OnIncomeVsExpenseSelected">
                    <ApexPointSeries TItem="ChartPoint"
                                     Items="IncomeData"
                                     SeriesType="SeriesType.Bar"
                                     Name="収入"
                                     XValue="@(e => e.Label)"
                                     YValue="@(e => e.Value)" />
                    <ApexPointSeries TItem="ChartPoint"
                                     Items="MonthlyDebitData"
                                     SeriesType="SeriesType.Bar"
                                     Name="支出"
                                     XValue="@(e => e.Label)"
                                     YValue="@(e => e.Value)" />
                    <ApexPointSeries TItem="ChartPoint"
                                     Items="NetData"
                                     SeriesType="SeriesType.Line"
                                     Name="収支"
                                     XValue="@(e => e.Label)"
                                     YValue="@(e => e.Value)" />
                </ApexChart>
            }
            else { <div class="graph-placeholder">データなし</div> }
        </div>

        <!-- 〔収入内訳｜口座残高〕の2列ブロック -->
        <div class="graph-row2">
            <!-- 収入の内訳推移（給料・ボーナス・臨時収入を入力名ごとに積み上げ） -->
            <div class="graph-card">
                <h4>収入の内訳推移</h4>
                @if (IncomeBreakdown.Any())
                {
                    <ApexChart TItem="ChartPoint" Options="IncomeBreakdownOptions" @key="@($"inc-{SelectedPeriod}-{_maskRev}")">
                        @foreach (var s in IncomeBreakdown)
                        {
                            <ApexPointSeries TItem="ChartPoint"
                                             Items="s.Data"
                                             SeriesType="SeriesType.Bar"
                                             Name="@s.Name"
                                             XValue="@(e => e.Label)"
                                             YValue="@(e => e.Value)" />
                        }
                    </ApexChart>
                }
                else { <div class="graph-placeholder">データなし</div> }
            </div>

            <!-- 口座別月末残高推移 -->
            <div class="graph-card">
                <h4>口座別 月末残高推移</h4>
                @if (BalanceSeriesData.Any())
                {
                    <ApexChart TItem="ChartPoint" Options="BalanceLineOptions" @key="@($"bal-{SelectedPeriod}-{_maskRev}")">
                        @foreach (var series in BalanceSeriesData)
                        {
                            <ApexPointSeries TItem="ChartPoint"
                                             Items="series.Value"
                                             SeriesType="SeriesType.Line"
                                             Name="@series.Key"
                                             XValue="@(e => e.Label)"
                                             YValue="@(e => e.Value)" />
                        }
                    </ApexChart>
                }
                else { <div class="graph-placeholder">データなし</div> }
            </div>
        </div>

        <!-- 〔カテゴリ｜カード〕の2列ブロック（ドーナツ＋一覧） -->
        <div class="graph-row2">
            <SpendBreakdownCard Title="カテゴリ別 支出（カード明細）"
                                FullWidth="false"
                                ItemColumnLabel="カテゴリ"
                                Items="CategorySpendData"
                                Total="CategoryTotal"
                                Options="DonutOptions"
                                RenderKey="@($"cat-{SelectedPeriod}-{_maskRev}")"
                                EmptyMessage="カード明細がありません"
                                OnRowClick="OpenCatDetail"
                                OnSliceSelected="OnSliceSelected" />

            <SpendBreakdownCard Title="カード別 利用額"
                                FullWidth="false"
                                ItemColumnLabel="カード"
                                Items="CardSpendData"
                                Total="CardTotal"
                                Options="CardDonutOptions"
                                RenderKey="@($"card-{SelectedPeriod}-{_maskRev}")"
                                EmptyMessage="カード明細がありません"
                                OnRowClick="OpenCardDetail"
                                OnSliceSelected="OnCardSliceSelected" />
        </div>

    </div>
    }

    @if (_detail is not null)
    {
        <DetailDialog Title="@_detail.Title" Color="@_detail.Color" Count="_detail.Count"
                      Total="_detail.Total" SubLabel="@RangeLabel" Rows="_detail.Rows"
                      ShowCategorize="_detail.ShowCategorize" OnCategorize="OnCategorize"
                      OnClose="CloseDetail" />
    }

    @if (_breakdown is not null)
    {
        <BreakdownDialog Title="@_breakdown.Title" SubLabel="@RangeLabel"
                         Total="_breakdown.Total" Items="_breakdown.Items"
                         OnClose="CloseBreakdown" />
    }
</div>
