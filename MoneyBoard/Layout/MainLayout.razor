@inherits LayoutComponentBase
@inject ViewportService Viewport
@inject AmountMaskService MaskSvc
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject LedgerService Svc
@implements IDisposable

@* IsMobile / IsMasked を全ページへ配布。スマホ時はアプリシェル（縦flex）で中身(.app-scroll)だけ
   内部スクロールさせ下部バーを最下段に常時在席させる。PC は左サイドナビ＋本文の横並び。 *@
<CascadingValue Value="Viewport.IsMobile" Name="IsMobile">
<CascadingValue Value="MaskSvc.IsMasked" Name="IsMasked">
    <div class="app-shell @(Viewport.IsMobile ? "is-mobile" : "has-sidenav")">
        @if (!Viewport.IsMobile)
        {
            <SideNav />
        }
        <div class="app-scroll">
            @Body
        </div>
        @if (Viewport.IsMobile)
        {
            <BottomNav />
        }
    </div>
</CascadingValue>
</CascadingValue>

@code {
    protected override async Task OnInitializedAsync()
    {
        Viewport.Changed += OnViewportChanged;
        MaskSvc.Changed += OnMaskChanged;
        Nav.LocationChanged += OnLocationChanged;
        await Viewport.InitAsync();
        await MaskSvc.InitAsync();
        StateHasChanged();
    }

    private void OnViewportChanged() => InvokeAsync(StateHasChanged);
    private void OnMaskChanged() => InvokeAsync(StateHasChanged);

    // スマホはタブ/ページ遷移ごとに内部スクロールを先頭へ戻す（位置の持ち越しを防ぐ）。
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (!Viewport.IsMobile) return;
        // 月次→カードの「該当カードへスクロール」遷移中は、その後の scrollIntoView を
        // 上書きしないよう先頭リセットを抑止する。
        if (Svc.ScrollToCardId != null) return;
        InvokeAsync(async () =>
        {
            try { await JS.InvokeVoidAsync("moneyboardViewport.scrollAppTop"); }
            catch { /* JS 未準備時は無視 */ }
        });
    }

    public void Dispose()
    {
        Viewport.Changed -= OnViewportChanged;
        MaskSvc.Changed -= OnMaskChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
