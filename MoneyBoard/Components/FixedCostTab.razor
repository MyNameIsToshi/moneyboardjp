@inject LedgerService Svc

<div class="panel">
    <div class="panel-head">
        <h3>固定費設定</h3>
        <button class="btn" @onclick="AddClicked">＋ 追加</button>
    </div>

    @if (Svc.State.FixedCosts.Count == 0)
    {
        <div class="none">固定費が登録されていません。</div>
    }
    else
    {
        @if (IsFilterActive)
        {
            <div class="fc-filter-note">口座でフィルター中（ドラッグ並べ替えは無効）</div>
        }

        <div class="fc-head">
            <span></span>
            <span>項目名</span>
            <span class="fc-th-filter">
                口座
                <button class="fc-filter-btn @(IsFilterActive ? "active" : "")"
                        @onclick="ToggleFilterMenu" title="口座でフィルター">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
                        <path d="M2.5 3.5 H13.5 L9 8.5 V11.5 L7 12.5 V8.5 Z" />
                    </svg>
                </button>
                @if (_filterOpen)
                {
                    <div class="fc-filter-menu" @onclick:stopPropagation="true">
                        @foreach (var a in Svc.ActiveAccounts)
                        {
                            <label class="fc-filter-item">
                                <input type="checkbox" checked="@IsChecked(a.Id)"
                                       @onchange="() => ToggleAccount(a.Id)" />
                                <span>@a.Name</span>
                            </label>
                        }
                        <div class="fc-filter-actions">
                            <button class="btn" @onclick="ClearFilter">すべて表示</button>
                        </div>
                    </div>
                }
            </span>
            <span>通常月金額</span>
            <span></span>
        </div>

        @if (_filterOpen)
        {
            <div class="fc-filter-backdrop" @onclick="() => _filterOpen = false"></div>
        }

        @if (!DisplayedFixedCosts.Any())
        {
            <div class="none">該当する固定費がありません。</div>
        }

        @foreach (var fc in DisplayedFixedCosts)
        {
            @if (IsMobile)
            {
                <button class="list-card" @onclick="() => OpenEdit(fc.Id)">
                    <div class="list-card-main">
                        <span class="list-card-name">@fc.Name</span>
                        <span class="list-card-amount">¥@fc.Amount.ToString("#,0")</span>
                    </div>
                    <div class="list-card-sub">
                        <span>@AccountName(fc.AccountId)</span>
                        <span class="list-card-chev">›</span>
                    </div>
                </button>
            }
            else
            {
            var expanded = ExpandedIds.Contains(fc.Id);
            <div class="fc-item @(DragOverId == fc.Id ? "drag-over" : "")"
                 draggable="@(IsManualOrder ? "true" : "false")"
                 @ondragstart="() => OnDragStart(fc.Id)"
                 @ondragover:preventDefault="true"
                 @ondragover="() => OnDragOver(fc.Id)"
                 @ondrop="() => OnDrop(fc.Id)"
                 @ondragend="OnDragEnd">
                <div class="fc-row">
                    @if (IsManualOrder)
                    {
                        <span class="drag-handle">⠿</span>
                    }
                    else
                    {
                        <span></span>
                    }
                    <input @bind="fc.Name" @bind:after="SaveWithReload" placeholder="項目名" />
                    <select @bind="fc.AccountId" @bind:after="SaveWithReload">
                        <option value="">口座を選択</option>
                        @foreach (var a in Svc.ActiveAccounts)
                        {
                            <option value="@a.Id">@a.Name</option>
                        }
                    </select>
                    <AmountInput CssClass="ra" Value="@fc.Amount" ValueChanged="v => { fc.Amount = v; RequestSaveWithReload(); }" />
                    <button class="x" @onclick="() => RemoveFixedCost(fc.Id)">✕</button>
                </div>

                <button class="fc-expand" @onclick="() => ToggleExpand(fc.Id)">
                    @(expanded ? "▼" : "▶") 期間・ボーナス設定（@SummaryText(fc)）
                </button>

                @if (expanded)
                {
                    <div class="fc-detail">
                        <div class="detail-row">
                            <span class="detail-lab">開始年月</span>
                            <select value="@StartYear(fc)"
                                    @onchange="e => SetStartYear(fc, e.Value?.ToString())">
                                <option value="">未設定</option>
                                @foreach (var y in YearRange())
                                {
                                    <option value="@y">@y 年</option>
                                }
                            </select>
                            <select value="@StartMonth(fc)"
                                    @onchange="e => SetStartMonth(fc, e.Value?.ToString())">
                                <option value="">—</option>
                                @for (int mi = 1; mi <= 12; mi++)
                                {
                                    var label = mi + " 月";
                                    var val = mi.ToString();
                                    <option value="@val">@label</option>
                                }
                            </select>
                        </div>
                        <div class="detail-row">
                            <span class="detail-lab">終了年月</span>
                            <select value="@EndYear(fc)"
                                    @onchange="e => SetEndYear(fc, e.Value?.ToString())">
                                <option value="">未設定</option>
                                @foreach (var y in YearRange())
                                {
                                    <option value="@y">@y 年</option>
                                }
                            </select>
                            <select value="@EndMonth(fc)"
                                    @onchange="e => SetEndMonth(fc, e.Value?.ToString())">
                                <option value="">—</option>
                                @for (int mi = 1; mi <= 12; mi++)
                                {
                                    var label = mi + " 月";
                                    var val = mi.ToString();
                                    <option value="@val">@label</option>
                                }
                            </select>
                        </div>
                        <div class="detail-row" style="flex-direction:column;align-items:flex-start;gap:6px">
                            <span class="detail-lab">ボーナス払い</span>
                            @if (fc.BonusSettings.Count > 0)
                            {
                                <div class="bonus-list">
                                    <div class="bonus-row-head">
                                        <span>対象月</span><span>種別</span><span>金額</span><span></span>
                                    </div>
                                    @foreach (var b in fc.BonusSettings)
                                    {
                                        <div class="bonus-row">
                                            <select @bind="b.Month" @bind:after="SaveWithReload">
                                                @for (int mi = 1; mi <= 12; mi++)
                                                {
                                                    <option value="@mi">@mi 月</option>
                                                }
                                            </select>
                                            <select @bind="b.Type" @bind:after="SaveWithReload">
                                                <option value="@BonusType.Add">上乗せ</option>
                                                <option value="@BonusType.Separate">別額</option>
                                            </select>
                                            <AmountInput CssClass="ra" Value="@b.Amount" ValueChanged="v => { b.Amount = v; RequestSaveWithReload(); }" />
                                            <button class="x" @onclick="() => RemoveBonus(fc, b.Id)">✕</button>
                                        </div>
                                    }
                                </div>
                            }
                            <button class="add-line" @onclick="() => AddBonus(fc)">＋ ボーナス月を追加</button>
                        </div>
                    </div>
                }
            </div>
            }
        }
    }
</div>

<div class="foot">
    開始・終了年月は任意です（未設定 = 開始なし / 無期限）。終了月はその月を含みます。<br />
    マスタの変更は未作成の月を開いたときから反映されます。作成済みの月は月次管理の「↺ 再読み込み」で手動反映できます。
</div>

<!-- 口座未登録警告 -->
<WarnDialog IsVisible="@ShowNoAccountWarn"
            Title="口座が登録されていません"
            Messages="@(new List<string> { "固定費を追加するには、先に口座設定タブで口座を登録してください。" })"
            SubMessage=""
            OnClose="() => ShowNoAccountWarn = false" />

<!-- 追加ダイアログ -->
@if (ShowAddDialog)
{
    <div class="dialog-overlay" @onclick="CloseAddDialog">
        <div class="dialog-box" @onclick:stopPropagation="true">
            <h4>固定費を追加</h4>
            <div class="dialog-form">
                <label>項目名</label>
                <input @bind="NewName" placeholder="例：家賃" @bind:event="oninput" />
                <label>口座</label>
                <select @bind="NewAccountId">
                    <option value="">口座を選択</option>
                    @foreach (var a in Svc.ActiveAccounts)
                    {
                        <option value="@a.Id">@a.Name</option>
                    }
                </select>
                <label>金額</label>
                <AmountInput CssClass="ra" Value="@NewAmount" ValueChanged="v => NewAmount = v" />
            </div>
            @if (!string.IsNullOrEmpty(AddError))
            {
                <div class="dialog-error">@AddError</div>
            }
            <div class="dialog-btns">
                <button class="btn" @onclick="CloseAddDialog">キャンセル</button>
                <button class="btn primary" @onclick="ExecuteAdd">追加する</button>
            </div>
        </div>
    </div>
}

<ConfirmDialog IsVisible="@ShowConfirm"
               Title="固定費を削除しますか？"
               Message="@("この操作は取り消せません。\n当月以降の月次からは自動的に削除されます。\n過去月の明細はそのまま残ります。")"
               ConfirmText="削除する"
               OnConfirm="ExecuteDelete"
               OnCancel="CancelDelete" />

<!-- スマホ：サマリーカードのタップで開く編集シート -->
<BottomSheet IsVisible="@(Editing is not null)" Title="固定費を編集" OnClose="CloseEdit">
    <ChildContent>
        @if (Editing is not null)
        {
            <div class="sheet-field">
                <label>項目名</label>
                <input @bind="Editing.Name" @bind:after="SaveWithReload" placeholder="項目名" />
            </div>
            <div class="sheet-field">
                <label>口座</label>
                <select @bind="Editing.AccountId" @bind:after="SaveWithReload">
                    <option value="">口座を選択</option>
                    @foreach (var a in Svc.ActiveAccounts)
                    {
                        <option value="@a.Id">@a.Name</option>
                    }
                </select>
            </div>
            <div class="sheet-field">
                <label>通常月金額</label>
                <AmountInput CssClass="ra" Value="@Editing.Amount" ValueChanged="v => { Editing.Amount = v; RequestSaveWithReload(); }" />
            </div>
            <div class="sheet-field">
                <label>開始年月</label>
                <div class="sheet-inline">
                    <select value="@StartYear(Editing)" @onchange="e => SetStartYear(Editing, e.Value?.ToString())">
                        <option value="">未設定</option>
                        @foreach (var y in YearRange())
                        {
                            <option value="@y">@y 年</option>
                        }
                    </select>
                    <select value="@StartMonth(Editing)" @onchange="e => SetStartMonth(Editing, e.Value?.ToString())">
                        <option value="">—</option>
                        @for (int mi = 1; mi <= 12; mi++)
                        {
                            var val = mi.ToString();
                            <option value="@val">@mi 月</option>
                        }
                    </select>
                </div>
            </div>
            <div class="sheet-field">
                <label>終了年月</label>
                <div class="sheet-inline">
                    <select value="@EndYear(Editing)" @onchange="e => SetEndYear(Editing, e.Value?.ToString())">
                        <option value="">未設定</option>
                        @foreach (var y in YearRange())
                        {
                            <option value="@y">@y 年</option>
                        }
                    </select>
                    <select value="@EndMonth(Editing)" @onchange="e => SetEndMonth(Editing, e.Value?.ToString())">
                        <option value="">—</option>
                        @for (int mi = 1; mi <= 12; mi++)
                        {
                            var val = mi.ToString();
                            <option value="@val">@mi 月</option>
                        }
                    </select>
                </div>
            </div>
            <div class="sheet-field">
                <label>ボーナス払い</label>
                @if (Editing.BonusSettings.Count > 0)
                {
                    <div class="bonus-list">
                        <div class="bonus-row-head">
                            <span>対象月</span><span>種別</span><span>金額</span><span></span>
                        </div>
                        @foreach (var b in Editing.BonusSettings)
                        {
                            <div class="bonus-row">
                                <select @bind="b.Month" @bind:after="SaveWithReload">
                                    @for (int mi = 1; mi <= 12; mi++)
                                    {
                                        <option value="@mi">@mi 月</option>
                                    }
                                </select>
                                <select @bind="b.Type" @bind:after="SaveWithReload">
                                    <option value="@BonusType.Add">上乗せ</option>
                                    <option value="@BonusType.Separate">別額</option>
                                </select>
                                <AmountInput CssClass="ra" Value="@b.Amount" ValueChanged="v => { b.Amount = v; RequestSaveWithReload(); }" />
                                <button class="x" @onclick="() => RemoveBonus(Editing, b.Id)">✕</button>
                            </div>
                        }
                    </div>
                }
                <button class="add-line" @onclick="() => AddBonus(Editing)">＋ ボーナス月を追加</button>
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button class="btn danger" @onclick="DeleteEditing">削除</button>
        <button class="btn primary" style="margin-left:auto" @onclick="CloseEdit">完了</button>
    </FooterContent>
</BottomSheet>

@code {
    [CascadingParameter(Name = "IsMobile")] public bool IsMobile { get; set; }

    // スマホ：編集シートで開いている固定費（id）。直接その固定費を編集（即時保存）。
    private string? _editId;
    private bool _isNew;   // ＋追加で開いた新規項目か（未入力のまま閉じたら破棄する）
    private FixedCost? Editing => _editId is null ? null : Svc.State.FixedCosts.FirstOrDefault(f => f.Id == _editId);
    private void OpenEdit(string id) { _editId = id; _isNew = false; }

    private void CloseEdit()
    {
        // 値未入力（項目名が空）のまま閉じた新規項目は追加しない（破棄）。
        if (_isNew && Editing is { } fc && string.IsNullOrWhiteSpace(fc.Name))
        {
            Svc.State.FixedCosts.RemoveAll(f => f.Id == _editId);
            SaveWithReload();
        }
        _editId = null;
        _isNew = false;
    }
    private string AccountName(string id) => Svc.ActiveAccounts.FirstOrDefault(a => a.Id == id)?.Name ?? "口座未選択";

    // シートから削除：シートを閉じてから確認ダイアログを出す（重なり順の都合）。
    private void DeleteEditing()
    {
        var id = _editId;
        _editId = null;
        if (id is not null) RemoveFixedCost(id);
    }

    // ＋追加：スマホは空の固定費を作ってそのまま編集シートを開く。PCは従来の追加ダイアログ。
    private void AddClicked()
    {
        if (!Svc.ActiveAccounts.Any()) { ShowNoAccountWarn = true; return; }
        if (IsMobile)
        {
            var fc = new FixedCost
            {
                Name = "",
                AccountId = Svc.ActiveAccounts.First().Id,
                Amount = 0,
                SortOrder = Svc.State.FixedCosts.Count
            };
            Svc.State.FixedCosts.Add(fc);
            SaveWithReload();
            _editId = fc.Id;
            _isNew = true;
        }
        else OpenAddDialog();
    }

    // ── 口座フィルター（Excel風・表示のみ・永続化しない。フィルター中は D&D 無効）──
    // _checked == null は「全口座表示（フィルターなし）」。部分選択時のみ set を保持する。
    private HashSet<string>? _checked;
    private bool _filterOpen;

    private bool IsChecked(string accountId) => _checked == null || _checked.Contains(accountId);
    private bool IsFilterActive => _checked != null;
    // フィルターしていないときだけ手動 D&D 並べ替えを許可する
    private bool IsManualOrder => !IsFilterActive;

    private void ToggleFilterMenu() => _filterOpen = !_filterOpen;

    private void ToggleAccount(string accountId)
    {
        _checked ??= Svc.ActiveAccounts.Select(a => a.Id).ToHashSet();
        if (!_checked.Remove(accountId)) _checked.Add(accountId);
        // 全口座が選択された状態に戻ったらフィルター解除（null 化）
        if (Svc.ActiveAccounts.All(a => _checked.Contains(a.Id))) _checked = null;
    }

    private void ClearFilter() { _checked = null; _filterOpen = false; }

    private IEnumerable<FixedCost> DisplayedFixedCosts =>
        _checked == null
            ? Svc.State.FixedCosts                                        // 全表示（手動順）
            : Svc.State.FixedCosts.Where(f => _checked.Contains(f.AccountId));

    private HashSet<string> ExpandedIds = new();
    private void Save() => _ = Svc.SaveAsync();
    // 構造変更・単発イベント用（即時保存）
    private void SaveWithReload() { Svc.OnFixedCostChanged(); _ = Svc.SaveAsync(); }
    // 金額入力など高頻度の編集用（再展開は即時・メモリ内、保存はデバウンス）
    private void RequestSaveWithReload() { Svc.OnFixedCostChanged(); Svc.RequestSave(); }
    private void ToggleExpand(string id) { if (!ExpandedIds.Remove(id)) ExpandedIds.Add(id); }

    // ── 追加ダイアログ ──────────────────────────────
    private bool ShowAddDialog = false;
    private string NewName = "";
    private string NewAccountId = "";
    private decimal NewAmount = 0;
    private string AddError = "";

    private bool ShowNoAccountWarn = false;

    private void OpenAddDialog()
    {
        if (!Svc.ActiveAccounts.Any())
        {
            ShowNoAccountWarn = true;
            return;
        }
        NewName      = "";
        NewAccountId = Svc.ActiveAccounts.FirstOrDefault()?.Id ?? "";
        NewAmount    = 0;
        AddError     = "";
        ShowAddDialog = true;
    }

    private void CloseAddDialog() => ShowAddDialog = false;

    private void ExecuteAdd()
    {
        if (string.IsNullOrWhiteSpace(NewName))    { AddError = "項目名を入力してください。"; return; }
        if (string.IsNullOrWhiteSpace(NewAccountId)) { AddError = "口座を選択してください。"; return; }

        Svc.State.FixedCosts.Add(new FixedCost
        {
            Name      = NewName.Trim(),
            AccountId = NewAccountId,
            Amount    = NewAmount,
            SortOrder = Svc.State.FixedCosts.Count
        });
        SaveWithReload();
        ShowAddDialog = false;
    }

    // ── ドラッグ＆ドロップ並び替え ──────────────────
    private string? DragSourceId = null;
    private string? DragOverId   = null;

    private void OnDragStart(string id) { if (IsManualOrder) DragSourceId = id; }
    private void OnDragOver(string id)  { if (IsManualOrder) DragOverId   = id; }

    private void OnDrop(string targetId)
    {
        if (!IsManualOrder) return;
        if (DragSourceId == null || DragSourceId == targetId) return;

        var list = Svc.State.FixedCosts;
        var srcIdx = list.FindIndex(f => f.Id == DragSourceId);
        var tgtIdx = list.FindIndex(f => f.Id == targetId);
        if (srcIdx < 0 || tgtIdx < 0) return;

        var item = list[srcIdx];
        list.RemoveAt(srcIdx);
        list.Insert(tgtIdx, item);

        // SortOrder を連番に振り直す
        for (int i = 0; i < list.Count; i++) list[i].SortOrder = i;

        SaveWithReload();
    }

    private void OnDragEnd()
    {
        DragSourceId = null;
        DragOverId   = null;
    }

    // ── 削除 ────────────────────────────────────────
    private string? PendingDeleteId = null;
    private bool ShowConfirm = false;

    private void RemoveFixedCost(string id) { PendingDeleteId = id; ShowConfirm = true; }

    private void ExecuteDelete()
    {
        if (PendingDeleteId != null) { Svc.State.FixedCosts.RemoveAll(f => f.Id == PendingDeleteId); SaveWithReload(); }
        PendingDeleteId = null;
        ShowConfirm = false;
    }

    private void CancelDelete() { PendingDeleteId = null; ShowConfirm = false; }

    private void AddBonus(FixedCost fc)    { fc.BonusSettings.Add(new BonusSetting { Month = 6 }); SaveWithReload(); }
    private void RemoveBonus(FixedCost fc, string bid) { fc.BonusSettings.RemoveAll(b => b.Id == bid); SaveWithReload(); }

    // ── 年月ヘルパー ────────────────────────────────
    // StartYm/EndYm は null / "yyyy"（年のみ）/ "yyyyMM" の3形態。
    private static IEnumerable<int> YearRange() => Enumerable.Range(DateTime.Today.Year - 5, 31);

    private static string YearPart(string? ym)  => ym is { Length: >= 4 } ? ym[..4] : "";
    private static string MonthPart(string? ym) => ym is { Length: 6 } ? int.Parse(ym[4..6]).ToString() : "";

    // 年・月のドロップダウン値から StartYm/EndYm を組み立てる（月未選択なら年のみ）。
    private static string? ComposeYm(string? year, string? month)
    {
        if (string.IsNullOrEmpty(year)) return null;
        return string.IsNullOrEmpty(month) ? year : $"{year}{int.Parse(month):D2}";
    }

    private static string StartYear(FixedCost fc)  => YearPart(fc.StartYm);
    private static string StartMonth(FixedCost fc) => MonthPart(fc.StartYm);
    private static string EndYear(FixedCost fc)    => YearPart(fc.EndYm);
    private static string EndMonth(FixedCost fc)   => MonthPart(fc.EndYm);

    private void SetStartYear(FixedCost fc, string? y)  { fc.StartYm = ComposeYm(y, StartMonth(fc)); SaveWithReload(); }
    private void SetStartMonth(FixedCost fc, string? m) { fc.StartYm = ComposeYm(StartYear(fc), m);  SaveWithReload(); }
    private void SetEndYear(FixedCost fc, string? y)    { fc.EndYm   = ComposeYm(y, EndMonth(fc));    SaveWithReload(); }
    private void SetEndMonth(FixedCost fc, string? m)   { fc.EndYm   = ComposeYm(EndYear(fc), m);     SaveWithReload(); }

    private static string SummaryText(FixedCost fc)
    {
        var start = fc.StartYm == null ? "開始なし〜" : FmtBound(fc.StartYm) + "〜";
        var end   = fc.EndYm   == null ? "無期限"     : FmtBound(fc.EndYm);
        var bonus = fc.BonusSettings.Count > 0 ? $"ボーナス{fc.BonusSettings.Count}件" : "ボーナスなし";
        return $"{start}{end}・{bonus}";
    }

    // "yyyy年m月"（月あり）または "yyyy年"（年のみ）
    private static string FmtBound(string ym)
    {
        var month = MonthPart(ym);
        return month != "" ? $"{YearPart(ym)}年{month}月" : $"{YearPart(ym)}年";
    }
}
