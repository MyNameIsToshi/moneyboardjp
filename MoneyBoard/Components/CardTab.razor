@inject LedgerService Svc
@inject IJSRuntime JS

<div>
    <div class="top">
        <div></div>
        <div class="topright">
            <button class="btn" @onclick="OpenBulk">一括カテゴリ</button>
            <div class="monthnav">
                <button @onclick="Prev">‹</button>
                <div class="m">@LedgerService.Label(Svc.CardMonth)</div>
                <button @onclick="Next">›</button>
                <CycleInfo Ym="@Svc.CardMonth" />
            </div>
        </div>
    </div>

    @if (ImportMessage != null)
    {
        <div class="import-msg">
            <span>@ImportMessage</span>
            <button class="x" @onclick="() => ImportMessage = null">✕</button>
        </div>
    }

    @if (Svc.CardsOrdered.Count == 0)
    {
        <div class="none">カードが登録されていません。マイページのカード設定で追加してください。</div>
    }
    else
    {
        @foreach (var card in Svc.CardsOrdered)
        {
            var details = DetailsFor(card.Id);
            var collapsed = IsCollapsed(card.Id);
            <div class="card-panel" id="card-@card.Id">
                <div class="card-panel-head">
                    <button class="card-collapse" @onclick="() => ToggleCollapse(card.Id)"
                            title="@(collapsed ? "開く" : "たたむ")">@(collapsed ? "▶" : "▼")</button>
                    <span class="card-title" @onclick="() => ToggleCollapse(card.Id)">💳 @card.Name</span>
                    <span class="card-acct-name">@Svc.AccountName(card.AccountId)</span>
                    @if (collapsed)
                    {
                        <span class="card-collapse-count">@details.Count 件</span>
                    }
                    <span class="card-total">@Yen(details.Sum(d => d.Amount))</span>
                    @if (!collapsed)
                    {
                        <button class="add-line" @onclick="() => AddDetail(card.Id)">＋ 明細を追加</button>
                        <button class="add-line" @onclick="() => OpenImport(card.Id)">📥 取込</button>
                    }
                </div>

                @if (!collapsed)
                {
                    var used = details.Sum(d => d.Amount);
                    <div class="card-billing">
                        <label class="cb-toggle">
                            <input type="checkbox" checked="@HasBilled(card.Id)"
                                   @onchange="e => ToggleBilled(card.Id, (bool)(e.Value ?? false), used)" />
                            <span>リボ・分割などで請求額が利用額と異なる</span>
                        </label>
                        @if (HasBilled(card.Id))
                        {
                            <div class="cb-fields">
                                <span class="cb-lab">今月の請求額（口座引落）</span>
                                <AmountInput CssClass="cb-input" Value="@(BilledOf(card.Id) ?? 0)"
                                             ValueChanged="v => OnBilledChanged(card.Id, v)" />
                                <span class="cb-carry">利用額（統計）@Yen(used)</span>
                            </div>
                        }
                    </div>
                }

                @if (collapsed)
                {
                    // たたんでいる間は明細を描画しない（件数と合計だけヘッダに表示）
                }
                else if (details.Count == 0)
                {
                    <div class="none">この月の明細はありません。</div>
                }
                else
                {
                    @if (!IsMobile)
                    {
                        <div class="cd-head">
                            <span class="sortable" @onclick="@(() => SetSort("date"))">@SortHead("date", "利用日")</span>
                            <span class="sortable" @onclick="@(() => SetSort("name"))">@SortHead("name", "利用先")</span>
                            <span class="sortable" @onclick="@(() => SetSort("category"))">@SortHead("category", "カテゴリ")</span>
                            <span class="sortable" @onclick="@(() => SetSort("amount"))">@SortHead("amount", "金額")</span>
                            <span></span>
                        </div>
                    }
                    @foreach (var d in details)
                    {
                        @if (IsMobile)
                        {
                            <button class="list-card" @onclick="() => OpenDetail(d.Id)">
                                <div class="list-card-main">
                                    <span class="list-card-name">@(string.IsNullOrEmpty(d.Name) ? "(利用先なし)" : d.Name)</span>
                                    <span class="list-card-amount">@Yen(d.Amount)</span>
                                </div>
                                <div class="list-card-sub">
                                    <span>@d.Date ・ <span class="color-dot" style="background:@DotColor(d.CategoryId)"></span> @CatName(d.CategoryId)</span>
                                    <span class="list-card-chev">›</span>
                                </div>
                            </button>
                        }
                        else
                        {
                        <div class="cd-row">
                            <input class="cd-date" type="date" value="@d.Date" @onchange="e => OnDateChange(d, e.Value)" />
                            <input class="cd-name" @bind="d.Name" @bind:after="() => OnNameChanged(d)" placeholder="利用先" />
                            <div class="cd-cat-cell">
                                <span class="color-dot" style="background:@DotColor(d.CategoryId)"></span>
                                <select class="cd-cat" @bind="d.CategoryId" @bind:after="Save">
                                    <option value="">未分類</option>
                                    @foreach (var c in Svc.CategoriesOrdered)
                                    {
                                        <option value="@c.Id">@c.Name</option>
                                    }
                                </select>
                            </div>
                            <AmountInput CssClass="cd-amt" Value="@d.Amount" ValueChanged="v => { d.Amount = v; OnAmountChanged(); }" />
                            <button class="x" @onclick="() => RemoveDetail(d.Id)">✕</button>
                        </div>
                        }
                    }
                }
            </div>
        }
    }
</div>

<div class="foot">
    明細の合計が、各カードに紐づく口座のその月の支出に反映されます。<br />
    リボ・分割で引き落とし額が異なる場合は「今月の請求額」を設定すると、口座末残高はその額で計算されます（明細＝利用額は統計にそのまま残ります）。<br />
    明細は表示中の月（@LedgerService.Label(Svc.CardMonth)）に計上されます。
</div>

@if (_importCardId != null)
{
    <div class="dialog-overlay" @onclick="() => _importCardId = null">
        <div class="dialog-box import-pick" @onclick:stopPropagation="true">
            <h4>CSVの種別を選択</h4>
            <div class="import-pick-list">
                @foreach (var fmt in Enum.GetValues<CardCsvFormat>())
                {
                    <label class="btn import-pick-item">
                        @CardCsvParser.Specs[fmt].Label
                        <InputFile OnChange="@(e => OnCsvSelected(e, fmt))" accept=".csv" class="import-input" />
                    </label>
                }
            </div>
            <div class="dialog-btns">
                <button class="btn" @onclick="() => _importCardId = null">キャンセル</button>
            </div>
        </div>
    </div>
}

@if (ShowBulk)
{
    <div class="dialog-overlay" @onclick="RequestCloseBulk">
        <div class="dialog-box bulk-box" @onclick:stopPropagation="true">
            <h4>一括カテゴリ設定（@LedgerService.Label(Svc.CardMonth)）</h4>
            @if (BulkGroups.Count == 0)
            {
                <div class="none">この月の明細がありません。</div>
            }
            else
            {
                <div class="bulk-batch">
                    <span>選択した利用先に一括設定:</span>
                    <div class="bulk-cat-cell bulk-batch-cat">
                        <span class="color-dot" style="background:@DotColor(_batchCat)"></span>
                        <select @bind="_batchCat">
                            <option value="">未分類</option>
                            @foreach (var c in Svc.CategoriesOrdered)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <button class="btn" disabled="@(_bulkChecked.Count == 0)" @onclick="ApplyBatchToChecked">
                        選択（@_bulkChecked.Count）に設定
                    </button>
                    <label class="bulk-filter">カテゴリ絞り込み
                        <select @bind="_bulkCatFilter">
                            <option value="@AllFilter">すべて</option>
                            <option value="">未分類</option>
                            @foreach (var c in Svc.CategoriesOrdered)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </label>
                </div>

                <div class="bulk-list">
                    <div class="bulk-row bulk-head">
                        <span class="bulk-check"><input type="checkbox" checked="@AllChecked" @onchange="ToggleAll" /></span>
                        <span class="sortable" @onclick="@(() => SetBulkSort("store"))">@BulkHead("store", "利用先")</span>
                        <span class="sortable" @onclick="@(() => SetBulkSort("count"))">@BulkHead("count", "件数")</span>
                        <span class="sortable" @onclick="@(() => SetBulkSort("total"))">@BulkHead("total", "金額")</span>
                        <span class="sortable" @onclick="@(() => SetBulkSort("category"))">@BulkHead("category", "カテゴリ")</span>
                    </div>
                    @if (DisplayedBulkGroups.Count == 0)
                    {
                        <div class="none">該当する利用先がありません。</div>
                    }
                    @foreach (var g in DisplayedBulkGroups)
                    {
                        <div class="bulk-row">
                            <span class="bulk-check"><input type="checkbox" checked="@_bulkChecked.Contains(g.Store)" @onchange="() => ToggleBulkCheck(g.Store)" /></span>
                            <span class="bulk-store" title="@g.Store">@g.Store</span>
                            <span class="bulk-count">@g.Count 件</span>
                            <span class="bulk-total">@Yen(g.Total)</span>
                            <div class="bulk-cat-cell">
                                <span class="color-dot" style="background:@DotColor(BulkSelection.GetValueOrDefault(g.Store))"></span>
                                <select value="@BulkSelection[g.Store]"
                                        @onchange="e => SetRowCategory(g.Store, e.Value?.ToString())">
                                    <option value="@KeepSentinel">変更しない</option>
                                    <option value="">未分類</option>
                                    @foreach (var c in Svc.CategoriesOrdered)
                                    {
                                        <option value="@c.Id">@c.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    }
                </div>
                <div class="dialog-message">
                    選んだ利用先のカテゴリを当月の明細にまとめて適用し、以降の取込でも自動分類します。「変更しない」はそのまま。
                </div>
            }
            <div class="dialog-btns">
                <button class="btn" @onclick="RequestCloseBulk">キャンセル</button>
                <button class="btn primary" @onclick="ApplyBulk">適用</button>
            </div>
        </div>
    </div>
}

<ConfirmDialog IsVisible="@_bulkConfirmCancel"
               Title="編集を破棄しますか？"
               Message="@("一括カテゴリの変更はまだ適用されていません。\n破棄して閉じてもよろしいですか？")"
               ConfirmText="破棄して閉じる"
               OnConfirm="DiscardBulk"
               OnCancel="KeepEditingBulk" />

<!-- スマホ：明細カードのタップで開く編集シート -->
<BottomSheet IsVisible="@(EditingDetail is not null)" Title="明細を編集" OnClose="CloseDetail">
    <ChildContent>
        @if (EditingDetail is { } d)
        {
            <div class="sheet-field">
                <label>利用日</label>
                <input type="date" value="@d.Date" @onchange="e => OnDateChange(d, e.Value)" />
            </div>
            <div class="sheet-field">
                <label>利用先</label>
                <input @bind="d.Name" @bind:after="() => OnNameChanged(d)" placeholder="利用先" />
            </div>
            <div class="sheet-field">
                <label>カテゴリ</label>
                <select @bind="d.CategoryId" @bind:after="Save">
                    <option value="">未分類</option>
                    @foreach (var c in Svc.CategoriesOrdered)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>
            <div class="sheet-field">
                <label>金額</label>
                <AmountInput CssClass="ra" Value="@d.Amount" ValueChanged="v => { d.Amount = v; OnAmountChanged(); }" />
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button class="btn danger" @onclick="DeleteEditingDetail">削除</button>
        <button class="btn primary" style="margin-left:auto" @onclick="CloseDetail">完了</button>
    </FooterContent>
</BottomSheet>
