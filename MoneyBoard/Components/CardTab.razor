@inject LedgerService Svc

<div>
    <div class="top">
        <div></div>
        <div class="topright">
            <div class="monthnav">
                <button @onclick="Prev">‹</button>
                <div class="m">@LedgerService.Label(Svc.CardMonth)</div>
                <button @onclick="Next">›</button>
            </div>
        </div>
    </div>

    @if (Svc.CardsOrdered.Count == 0)
    {
        <div class="none">カードが登録されていません。マイページのカード設定で追加してください。</div>
    }
    else
    {
        @foreach (var card in Svc.CardsOrdered)
        {
            var details = DetailsFor(card.Id);
            <div class="card-panel">
                <div class="card-panel-head">
                    <span class="card-title">💳 @card.Name</span>
                    <span class="card-acct-name">@Svc.AccountName(card.AccountId)</span>
                    <span class="card-total">@Yen(details.Sum(d => d.Amount))</span>
                    <button class="add-line" @onclick="() => AddDetail(card.Id)">＋ 明細を追加</button>
                </div>

                @if (details.Count == 0)
                {
                    <div class="none">この月の明細はありません。</div>
                }
                else
                {
                    <div class="cd-head">
                        <span>利用日</span><span>利用先</span><span>カテゴリ</span><span>金額</span><span></span>
                    </div>
                    @foreach (var d in details)
                    {
                        <div class="cd-row">
                            <input class="cd-date" type="date" value="@d.Date" @onchange="e => OnDateChange(d, e.Value)" />
                            <input class="cd-name" @bind="d.Name" @bind:after="Save" placeholder="利用先" />
                            <select class="cd-cat" @bind="d.CategoryId" @bind:after="Save">
                                <option value="">未分類</option>
                                @foreach (var c in Svc.CategoriesOrdered)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </select>
                            <AmountInput CssClass="cd-amt" Value="@d.Amount" ValueChanged="v => { d.Amount = v; OnAmountChanged(); }" />
                            <button class="x" @onclick="() => RemoveDetail(d.Id)">✕</button>
                        </div>
                    }
                }
            </div>
        }
    }
</div>

<div class="foot">
    明細の合計が、各カードに紐づく口座のその月の引き落としに反映されます。<br />
    明細は表示中の月（@LedgerService.Label(Svc.CardMonth)）に計上されます。
</div>

@code {
    private MonthData Mo = new();

    protected override void OnInitialized() => Mo = Svc.EnsureMonth(Svc.CardMonth);

    private List<CardDetail> DetailsFor(string cardId) =>
        Mo.CardDetails.Where(d => d.CardId == cardId).ToList();

    private static string Yen(decimal v) => "¥" + v.ToString("#,0");

    private void Prev() { Svc.CardMonth = LedgerService.PrevYm(Svc.CardMonth); Mo = Svc.EnsureMonth(Svc.CardMonth); }
    private void Next() { Svc.CardMonth = LedgerService.NextYm(Svc.CardMonth); Mo = Svc.EnsureMonth(Svc.CardMonth); }

    private void Save() => _ = Svc.SaveAsync();

    private void OnDateChange(CardDetail d, object? v) { d.Date = v?.ToString() ?? ""; Save(); }

    // 金額変更時のみカード Debit 合計が変わるため再計算（デバウンス保存）
    private void OnAmountChanged() { Svc.RecalcCards(Svc.CardMonth); Svc.RequestSave(); }

    private void AddDetail(string cardId)
    {
        Mo.CardDetails.Add(new CardDetail { CardId = cardId, Date = DateTime.Today.ToString("yyyy-MM-dd") });
        Svc.RecalcCards(Svc.CardMonth);
        Save();
    }

    private void RemoveDetail(string id)
    {
        Mo.CardDetails.RemoveAll(d => d.Id == id);
        Svc.RecalcCards(Svc.CardMonth);
        Save();
    }
}
