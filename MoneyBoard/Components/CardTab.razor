@inject LedgerService Svc
@inject IJSRuntime JS

<div>
    <div class="top">
        <div></div>
        <div class="topright">
            <button class="btn" @onclick="OpenBulk">一括カテゴリ</button>
            <div class="monthnav">
                <button @onclick="Prev">‹</button>
                <div class="m">@LedgerService.Label(Svc.CardMonth)</div>
                <button @onclick="Next">›</button>
            </div>
        </div>
    </div>

    @if (ImportMessage != null)
    {
        <div class="import-msg">
            <span>@ImportMessage</span>
            <button class="x" @onclick="() => ImportMessage = null">✕</button>
        </div>
    }

    @if (Svc.CardsOrdered.Count == 0)
    {
        <div class="none">カードが登録されていません。マイページのカード設定で追加してください。</div>
    }
    else
    {
        @foreach (var card in Svc.CardsOrdered)
        {
            var details = DetailsFor(card.Id);
            <div class="card-panel">
                <div class="card-panel-head">
                    <span class="card-title">💳 @card.Name</span>
                    <span class="card-acct-name">@Svc.AccountName(card.AccountId)</span>
                    <span class="card-total">@Yen(details.Sum(d => d.Amount))</span>
                    <button class="add-line" @onclick="() => AddDetail(card.Id)">＋ 明細を追加</button>
                    <label class="add-line import-label">📥 CSV取込<InputFile OnChange="@(e => OnCsvSelected(e, card.Id))" accept=".csv" class="import-input" /></label>
                </div>

                @if (details.Count == 0)
                {
                    <div class="none">この月の明細はありません。</div>
                }
                else
                {
                    <div class="cd-head">
                        <span>利用日</span><span>利用先</span><span>カテゴリ</span><span>金額</span><span></span>
                    </div>
                    @foreach (var d in details)
                    {
                        <div class="cd-row">
                            <input class="cd-date" type="date" value="@d.Date" @onchange="e => OnDateChange(d, e.Value)" />
                            <input class="cd-name" @bind="d.Name" @bind:after="Save" placeholder="利用先" />
                            <select class="cd-cat" @bind="d.CategoryId" @bind:after="Save">
                                <option value="">未分類</option>
                                @foreach (var c in Svc.CategoriesOrdered)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </select>
                            <AmountInput CssClass="cd-amt" Value="@d.Amount" ValueChanged="v => { d.Amount = v; OnAmountChanged(); }" />
                            <button class="x" @onclick="() => RemoveDetail(d.Id)">✕</button>
                        </div>
                    }
                }
            </div>
        }
    }
</div>

<div class="foot">
    明細の合計が、各カードに紐づく口座のその月の引き落としに反映されます。<br />
    明細は表示中の月（@LedgerService.Label(Svc.CardMonth)）に計上されます。
</div>

@if (ShowBulk)
{
    <div class="dialog-overlay" @onclick="() => ShowBulk = false">
        <div class="dialog-box bulk-box" @onclick:stopPropagation="true">
            <h4>一括カテゴリ設定（@LedgerService.Label(Svc.CardMonth)）</h4>
            @if (BulkGroups.Count == 0)
            {
                <div class="none">この月の明細がありません。</div>
            }
            else
            {
                <div class="bulk-list">
                    <div class="bulk-row bulk-head">
                        <span>利用先</span><span>件数</span><span>金額</span><span>カテゴリ</span>
                    </div>
                    @foreach (var g in BulkGroups)
                    {
                        <div class="bulk-row">
                            <span class="bulk-store" title="@g.Store">@g.Store</span>
                            <span class="bulk-count">@g.Count 件</span>
                            <span class="bulk-total">@Yen(g.Total)</span>
                            <select value="@BulkSelection[g.Store]"
                                    @onchange="e => BulkSelection[g.Store] = e.Value?.ToString() ?? KeepSentinel">
                                <option value="@KeepSentinel">変更しない</option>
                                <option value="">未分類</option>
                                @foreach (var c in Svc.CategoriesOrdered)
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            </select>
                        </div>
                    }
                </div>
                <div class="dialog-message">
                    選んだ利用先のカテゴリを当月の明細にまとめて適用し、以降の取込でも自動分類します。「変更しない」はそのまま。
                </div>
            }
            <div class="dialog-btns">
                <button class="btn" @onclick="() => ShowBulk = false">キャンセル</button>
                <button class="btn primary" @onclick="ApplyBulk">適用</button>
            </div>
        </div>
    </div>
}

@code {
    private MonthData Mo = new();

    protected override void OnInitialized() => Mo = Svc.EnsureMonth(Svc.CardMonth);

    private List<CardDetail> DetailsFor(string cardId) =>
        Mo.CardDetails.Where(d => d.CardId == cardId).ToList();

    private static string Yen(decimal v) => "¥" + v.ToString("#,0");

    private void Prev() { Svc.CardMonth = LedgerService.PrevYm(Svc.CardMonth); Mo = Svc.EnsureMonth(Svc.CardMonth); }
    private void Next() { Svc.CardMonth = LedgerService.NextYm(Svc.CardMonth); Mo = Svc.EnsureMonth(Svc.CardMonth); }

    private void Save() => _ = Svc.SaveAsync();

    private void OnDateChange(CardDetail d, object? v) { d.Date = v?.ToString() ?? ""; Save(); }

    // 金額変更時のみカード Debit 合計が変わるため再計算（デバウンス保存）
    private void OnAmountChanged() { Svc.RecalcCards(Svc.CardMonth); Svc.RequestSave(); }

    private void AddDetail(string cardId)
    {
        Mo.CardDetails.Add(new CardDetail { CardId = cardId, Date = DateTime.Today.ToString("yyyy-MM-dd") });
        Svc.RecalcCards(Svc.CardMonth);
        Save();
    }

    private void RemoveDetail(string id)
    {
        Mo.CardDetails.RemoveAll(d => d.Id == id);
        Svc.RecalcCards(Svc.CardMonth);
        Save();
    }

    // ── JCB CSV 取込（表示中の月へ・そのカードを全置換）──
    private string? ImportMessage;

    private async Task OnCsvSelected(InputFileChangeEventArgs e, string cardId)
    {
        var file = e.File;
        if (file == null) return;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5_000_000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var text = await JS.InvokeAsync<string>("decodeShiftJis", ms.ToArray());

            var parsed = JcbCsvParser.Parse(text, cardId);
            Svc.ApplyCategoryRules(parsed);   // 記憶済みの店名→カテゴリを自動適用

            // 全置換：このカードの当月明細を消して入れ直す
            Mo.CardDetails.RemoveAll(d => d.CardId == cardId);
            Mo.CardDetails.AddRange(parsed);
            Svc.RecalcCards(Svc.CardMonth);
            Save();

            ImportMessage = $"「{Svc.CardById(cardId)?.Name}」に {parsed.Count} 件を取り込みました（{LedgerService.Label(Svc.CardMonth)}・全置換）";
        }
        catch (Exception ex)
        {
            ImportMessage = $"取込に失敗しました: {ex.Message}";
        }
    }

    // ── 一括カテゴリ（利用先ごと・当月適用＋ルール記憶）──
    private const string KeepSentinel = "__keep__";
    private bool ShowBulk;
    private record StoreGroup(string Store, int Count, decimal Total);
    private List<StoreGroup> BulkGroups = new();
    private Dictionary<string, string> BulkSelection = new();

    private void OpenBulk()
    {
        BulkGroups = Mo.CardDetails
            .GroupBy(d => d.Name)
            .Select(g => new StoreGroup(g.Key, g.Count(), g.Sum(d => d.Amount)))
            .OrderByDescending(g => g.Total)
            .ToList();

        BulkSelection = new();
        foreach (var g in BulkGroups)
        {
            // 当該店名の明細カテゴリが揃っていれば初期選択、混在なら「変更しない」
            var cats = Mo.CardDetails.Where(d => d.Name == g.Store)
                .Select(d => d.CategoryId ?? "").Distinct().ToList();
            BulkSelection[g.Store] = cats.Count == 1 ? cats[0] : KeepSentinel;
        }
        ShowBulk = true;
    }

    private void ApplyBulk()
    {
        foreach (var g in BulkGroups)
        {
            var sel = BulkSelection.GetValueOrDefault(g.Store, KeepSentinel);
            if (sel == KeepSentinel) continue;   // 変更しない

            foreach (var d in Mo.CardDetails.Where(d => d.Name == g.Store))
                d.CategoryId = string.IsNullOrEmpty(sel) ? null : sel;

            // 店名→カテゴリのルールを記憶（未分類選択時は削除）
            if (string.IsNullOrEmpty(sel)) Svc.State.CategoryRules.Remove(g.Store);
            else Svc.State.CategoryRules[g.Store] = sel;
        }
        ShowBulk = false;
        Save();
    }
}
