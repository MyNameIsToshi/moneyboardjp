@* 明細ドリルダウンのモーダル（カテゴリ別／カード別の個別明細一覧）。 *@
<div class="dialog-overlay" @onclick="OnClose">
    <div class="dialog-box cat-detail-box" @onclick:stopPropagation="true">
        <div class="cat-detail-head">
            @if (!string.IsNullOrEmpty(Color))
            {
                <span class="color-dot" style="background:@Color"></span>
            }
            <h4>@Title の明細</h4>
            <button class="x" @onclick="OnClose">✕</button>
        </div>
        <div class="cat-detail-sub">@SubLabel ・ @Count 件 ・ 合計 @Yen(Total)</div>
        <div class="cat-detail-list">
            @foreach (var r in Rows)
            {
                <div class="spend-detail-row">
                    <span class="sd-date">@FmtDate(r.Date)</span>
                    <span class="sd-name" title="@r.Store">@r.Store</span>
                    <span class="sd-card">@r.Sub</span>
                    <span class="sd-amt">@Yen(r.Amount)</span>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Color { get; set; } = "";
    [Parameter] public int Count { get; set; }
    [Parameter] public decimal Total { get; set; }
    [Parameter] public string SubLabel { get; set; } = "";
    [Parameter] public List<DetailRow> Rows { get; set; } = new();
    [Parameter] public EventCallback OnClose { get; set; }

    // 明細1行。Sub はカテゴリ別=カード名 / カード別=カテゴリ名 を入れる補足列。
    public record DetailRow(string Date, string Store, string Sub, decimal Amount);

    private static string Yen(decimal v) => "¥" + v.ToString("#,0");
    private static string FmtDate(string d) => DateTime.TryParse(d, out var dt) ? dt.ToString("M/d") : d;
}
