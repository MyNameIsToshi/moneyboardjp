@inject LedgerService Svc

<div class="mypage-section">
    <h3>アカウント</h3>
    <div style="font-size:13px;color:var(--sub)">
        Google認証は今後実装予定です。
    </div>
</div>

<div class="mypage-section">
    <h3>データ管理</h3>
    <div class="mypage-row">
        <span>CSVエクスポート</span>
        <button class="btn" style="padding:5px 12px;font-size:13px" @onclick="ExportCsv">ダウンロード</button>
    </div>
</div>

<div class="mypage-section">
    <button class="mypage-collapse" @onclick='() => ToggleSection("category")'>
        <span>カード明細カテゴリ</span>
        <span class="mypage-chevron">@(IsOpen("category") ? "▼" : "▶")</span>
    </button>
    @if (IsOpen("category"))
    {
        <div class="mypage-collapse-body"><CategorySettings /></div>
    }
</div>

<div class="mypage-section">
    <button class="mypage-collapse" @onclick='() => ToggleSection("card")'>
        <span>カード設定</span>
        <span class="mypage-chevron">@(IsOpen("card") ? "▼" : "▶")</span>
    </button>
    @if (IsOpen("card"))
    {
        <div class="mypage-collapse-body"><CardSettings /></div>
    }
</div>

@code {
    // カテゴリ/カード設定は折りたたみ式（既定は畳んだ状態）
    private readonly HashSet<string> _open = new();
    private bool IsOpen(string key) => _open.Contains(key);
    private void ToggleSection(string key) { if (!_open.Remove(key)) _open.Add(key); }

    private void ExportCsv()
    {
        // Phase 1 では未実装（後で実装）
    }
}
