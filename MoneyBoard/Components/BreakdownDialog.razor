@* 収入/支出/固定費の項目別内訳（項目→期間合計・割合）。明細ダイアログ（DetailDialog）と同トーン。
   集計済みの項目一覧をそのまま表示するのみ（抽出・合計・割合の結果は親から渡る値のまま）。 *@
<div class="dialog-overlay dd-overlay" @onclick="OnClose">
    <div class="dialog-box dd-box" @onclick:stopPropagation="true">
        <div class="dd-grabber"></div>

        <div class="dd-head">
            <div class="dd-title"><span class="dd-title-main">@Title</span></div>
            <button class="dd-x msym" @onclick="OnClose" title="閉じる">close</button>
        </div>

        <div class="dd-total-row">
            <span class="dd-total">@Yen(Total)</span>
            <span class="dd-meta">@Items.Count 項目 ・ @SubLabel</span>
        </div>

        <div class="dd-list bd-list">
            @foreach (var it in Items)
            {
                <div class="bd-row">
                    <span class="bd-name" title="@it.Name">@it.Name</span>
                    <span class="bd-amt">@Yen(it.Amount)</span>
                    <span class="bd-pct">@Pct(it.Amount)</span>
                    <span class="dd-bar bd-bar"><i style="width:@BarPct(it.Amount)%"></i></span>
                </div>
            }
        </div>

        <div class="dd-foot">
            <span>@Items.Count 項目</span>
            <span>合計 <b>@Yen(Total)</b></span>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string SubLabel { get; set; } = "";
    [Parameter] public decimal Total { get; set; }
    [Parameter] public List<BreakdownItem> Items { get; set; } = new();
    [Parameter] public EventCallback OnClose { get; set; }

    public record BreakdownItem(string Name, decimal Amount);

    private decimal MaxAmount => Items.Count == 0 ? 0 : Items.Max(i => i.Amount);
    private string BarPct(decimal v) => MaxAmount == 0 ? "0" : (v / MaxAmount * 100).ToString("0.#");

    private string Pct(decimal v) => Total == 0 ? "0%" : (v / Total * 100).ToString("0.0") + "%";
}
