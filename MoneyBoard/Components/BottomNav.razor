@inject NavigationManager Nav
@inject AmountMaskService MaskSvc
@implements IDisposable

@* スマホ用の下部固定タブバー。表示可否は MainLayout が IsMobile で制御する。
   月次/カード/マイページは Home の "/?tab=" 経由、統計/資産は専用ルート。 *@
<nav class="botnav">
    <button class="botnav-item @(IsHomeTab("monthly") ? "active" : "")" @onclick='() => GoTab("monthly")'>
        <span class="bn-ico msym">calendar_month</span><span class="bn-lab">月次</span>
    </button>
    <button class="botnav-item @(IsHomeTab("card") ? "active" : "")" @onclick='() => GoTab("card")'>
        <span class="bn-ico msym">credit_card</span><span class="bn-lab">カード</span>
    </button>
    <button class="botnav-item @(IsRoute("/graph") ? "active" : "")" @onclick='() => Go("/graph")'>
        <span class="bn-ico msym">bar_chart</span><span class="bn-lab">統計</span>
    </button>
    <button class="botnav-item @(IsRoute("/portfolio") ? "active" : "")" @onclick='() => Go("/portfolio")'>
        <span class="bn-ico msym">savings</span><span class="bn-lab">資産</span>
    </button>
    <button class="botnav-item @(IsHomeTab("mypage") ? "active" : "")" @onclick='() => GoTab("mypage")'>
        <span class="bn-ico msym">person</span><span class="bn-lab">マイページ</span>
    </button>
    <button class="botnav-item botnav-mask @(MaskSvc.IsMasked ? "masked" : "")" @onclick="MaskSvc.ToggleAsync" title="@(MaskSvc.IsMasked ? "金額を表示する" : "金額を隠す")">
        <span class="bn-ico msym">@(MaskSvc.IsMasked ? "visibility_off" : "visibility")</span>
        <span class="bn-lab">@(MaskSvc.IsMasked ? "表示" : "隠す")</span>
    </button>
</nav>

@code {
    protected override void OnInitialized() => Nav.LocationChanged += OnLocationChanged;

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    // 現在 "/" に居て、?tab= が指定タブ（未指定なら monthly 既定）と一致するか。
    private bool IsHomeTab(string tab)
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        if (uri.AbsolutePath.TrimEnd('/') is not "") return false;
        var current = ParseTab(uri.Query);
        if (string.IsNullOrEmpty(current)) current = "monthly";
        return current == tab;
    }

    // "?tab=card&x=1" → "card"（依存を増やさないための簡易パース）
    private static string? ParseTab(string query)
    {
        query = query.TrimStart('?');
        foreach (var pair in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var eq = pair.IndexOf('=');
            if (eq > 0 && pair[..eq] == "tab")
                return Uri.UnescapeDataString(pair[(eq + 1)..]);
        }
        return null;
    }

    private bool IsRoute(string path)
        => Nav.ToAbsoluteUri(Nav.Uri).AbsolutePath.TrimEnd('/').Equals(path, StringComparison.OrdinalIgnoreCase);

    private void GoTab(string tab) => Nav.NavigateTo($"/?tab={tab}");
    private void Go(string path) => Nav.NavigateTo(path);

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
