@inject LedgerService Svc

<div class="set-head">
    <span class="set-chip c-account msym">account_balance</span>
    <span class="set-title">口座</span>
    <button class="set-add" @onclick="AddClicked"><span class="msym">add</span>追加</button>
</div>

@if (Svc.ActiveAccounts.Count == 0)
{
    <div class="none">口座が登録されていません。</div>
}
else if (IsMobile)
{
    @foreach (var a in Svc.ActiveAccounts)
    {
        <button class="list-card" @onclick="() => OpenEdit(a.Id)">
            <div class="cat-card-row">
                <span class="acct-row-chip msym">account_balance</span>
                <span class="list-card-name">@(string.IsNullOrEmpty(a.Name) ? "(名称未設定)" : a.Name)</span>
                <span class="list-card-chev msym">chevron_right</span>
            </div>
            @if (a.IsBonusAccount)
            {
                <div class="list-card-sub"><span class="bonus-tag">ボーナス受取</span></div>
            }
        </button>
    }
}
else
{
    <div class="acct-colhead">
        <span class="ch-name">口座名</span>
        <span class="ch-bonus">ボーナス受取</span>
    </div>
    <div class="set-list">
        @foreach (var a in Svc.ActiveAccounts)
        {
            <div class="acct-row">
                <span class="acct-row-chip msym">account_balance</span>
                <input class="set-input" @bind="a.Name" @bind:after="Save" placeholder="口座名" />
                <span class="acct-bonus">
                    <input type="radio" name="bonusAcct" class="radio-bonus"
                           checked="@a.IsBonusAccount"
                           @onchange="() => SetBonusAccount(a.Id)" />
                </span>
                <button class="set-del" @onclick="() => RequestDelete(a.Id)" title="削除"><span class="msym">close</span></button>
            </div>
        }
    </div>
}

<div class="set-note">
    ボーナス受取口座は1つだけ選択できます。<br />
    固定費で使用中、または現在月以降の月次データがある口座は削除できません。
</div>

<!-- 追加ダイアログ -->
@if (ShowAddDialog)
{
    <div class="dialog-overlay" @onclick="CloseAddDialog">
        <div class="dialog-box" @onclick:stopPropagation="true">
            <h4>口座を追加</h4>
            <div class="dialog-form">
                <label>口座名</label>
                <input @bind="NewName" placeholder="例：三菱UFJ 普通" @bind:event="oninput" />
            </div>
            @if (!string.IsNullOrEmpty(AddError))
            {
                <div class="dialog-error">@AddError</div>
            }
            <div class="dialog-btns">
                <button class="btn" @onclick="CloseAddDialog">キャンセル</button>
                <button class="btn primary" @onclick="ExecuteAdd">追加する</button>
            </div>
        </div>
    </div>
}

<!-- 削除確認ダイアログ -->
<ConfirmDialog IsVisible="@ShowConfirm"
               Title="口座を削除しますか？"
               Message="この操作は取り消せません。"
               ConfirmText="削除する"
               OnConfirm="ExecuteDelete"
               OnCancel="CancelDelete" />

<!-- 削除不可警告ダイアログ -->
<WarnDialog IsVisible="@ShowWarn"
            Title="口座を削除できません"
            Messages="@WarnMessages"
            SubMessage="@WarnSubMessage"
            OnClose="() => ShowWarn = false" />

<!-- スマホ：サマリーカードのタップで開く編集シート -->
<BottomSheet IsVisible="@(Editing is not null)" Title="口座を編集" OnClose="CloseEdit">
    <ChildContent>
        @if (Editing is not null)
        {
            <div class="sheet-field">
                <label>口座名</label>
                <input @bind="Editing.Name" @bind:after="Save" placeholder="口座名" />
            </div>
            <div class="sheet-field">
                <label>ボーナス受取口座</label>
                <label class="sheet-check">
                    <input type="checkbox" checked="@Editing.IsBonusAccount"
                           @onchange="e => SetBonus(Editing, (bool)(e.Value ?? false))" />
                    この口座でボーナスを受け取る
                </label>
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button class="btn danger" @onclick="DeleteEditing">削除</button>
        <button class="btn primary" style="margin-left:auto" @onclick="CloseEdit">完了</button>
    </FooterContent>
</BottomSheet>

@code {
    [CascadingParameter(Name = "IsMobile")] public bool IsMobile { get; set; }

    // スマホ：編集シートで開いている口座（直接編集・即時保存）。
    private string? _editId;
    private bool _isNew;   // ＋追加で開いた新規口座か（未入力のまま閉じたら破棄する）
    private Account? Editing => _editId is null ? null : Svc.State.Accounts.FirstOrDefault(a => a.Id == _editId);
    private void OpenEdit(string id) { _editId = id; _isNew = false; }

    private void CloseEdit()
    {
        // 口座名が空のまま閉じた新規口座は追加しない（破棄）。
        if (_isNew && Editing is { } a && string.IsNullOrWhiteSpace(a.Name))
        {
            Svc.State.Accounts.RemoveAll(x => x.Id == _editId);
            Save();
        }
        _editId = null;
        _isNew = false;
    }

    // ＋追加：スマホは空の口座を作ってそのまま編集シートを開く。PCは従来の追加ダイアログ。
    private void AddClicked()
    {
        if (IsMobile)
        {
            var a = new Account { Name = "", SortOrder = Svc.State.Accounts.Count };
            Svc.State.Accounts.Add(a);
            Save();
            _editId = a.Id;
            _isNew = true;
        }
        else OpenAddDialog();
    }

    private void SetBonus(Account a, bool val)
    {
        if (val) SetBonusAccount(a.Id);
        else { a.IsBonusAccount = false; Save(); }
    }

    // シートから削除：シートを閉じてから削除判定（使用中チェック→確認/警告）。
    private void DeleteEditing()
    {
        var id = _editId;
        _editId = null;
        if (id != null) RequestDelete(id);
    }

    private string NewName = "";
    private string AddError = "";
    private bool ShowAddDialog = false;
    private string? PendingDeleteId = null;
    private bool ShowConfirm = false;
    private bool ShowWarn = false;
    private List<string> WarnMessages = new();
    private string WarnSubMessage = "";

    private void Save() => _ = Svc.SaveAsync();

    private void SetBonusAccount(string id)
    {
        foreach (var a in Svc.State.Accounts)
            a.IsBonusAccount = a.Id == id;
        Save();
    }

    // ── 追加ダイアログ ──────────────────────────────
    private void OpenAddDialog()
    {
        NewName  = "";
        AddError = "";
        ShowAddDialog = true;
    }

    private void CloseAddDialog() => ShowAddDialog = false;

    private void ExecuteAdd()
    {
        if (string.IsNullOrWhiteSpace(NewName)) { AddError = "口座名を入力してください。"; return; }

        Svc.State.Accounts.Add(new Account
        {
            Name      = NewName.Trim(),
            SortOrder = Svc.State.Accounts.Count
        });
        NewName = "";
        Save();
        ShowAddDialog = false;
    }

    // ── 削除 ────────────────────────────────────────
    private void RequestDelete(string id)
    {
        WarnMessages.Clear();
        WarnSubMessage = "";

        var fcNames = Svc.GetFixedCostsUsingAccount(id);
        if (fcNames.Count > 0)
        {
            WarnMessages.Add($"以下の固定費で使用されています：{string.Join("、", fcNames)}");
            WarnSubMessage = "固定費設定から該当の固定費を変更または削除してください。";
            ShowWarn = true;
            return;
        }

        var cardNames = Svc.GetCardsUsingAccount(id);
        if (cardNames.Count > 0)
        {
            WarnMessages.Add($"以下のカードで使用されています：{string.Join("、", cardNames)}");
            WarnSubMessage = "マイページのカード設定から該当のカードを変更または削除してください。";
            ShowWarn = true;
            return;
        }

        var months = Svc.GetFutureMonthsUsingAccount(id);
        if (months.Count > 0)
        {
            WarnMessages.Add($"以下の年月にデータが存在します：{string.Join("、", months)}");
            WarnSubMessage = "該当月のデータを削除してから再度お試しください。";
            ShowWarn = true;
            return;
        }

        PendingDeleteId = id;
        ShowConfirm = true;
    }

    private void ExecuteDelete()
    {
        if (PendingDeleteId != null) { Svc.DeleteAccount(PendingDeleteId); Save(); }
        PendingDeleteId = null;
        ShowConfirm = false;
    }

    private void CancelDelete() { PendingDeleteId = null; ShowConfirm = false; }
}
