@* 金額入力の共通コンポーネント
   使い方: <AmountInput Value="@amount" ValueChanged="v => amount = v" />

   フォーカス中はカンマ整形せず「入力内容そのもの」を value に出すため、
   桁を途中挿入してもカーソルが末尾へ飛ばない。空欄も許可し 0 を出さない。
   blur 時にカンマ整形＋空欄→0 で確定する。
*@

<input class="@CssClass"
       inputmode="@(Decimals > 0 ? "decimal" : "numeric")"
       placeholder="@Placeholder"
       value="@DisplayValue"
       @onfocus="OnFocus"
       @oninput="OnInput"
       @onblur="OnBlur" />

@code {
    [Parameter] public decimal Value { get; set; }
    [Parameter] public EventCallback<decimal> ValueChanged { get; set; }
    [Parameter] public string CssClass { get; set; } = "num";
    [Parameter] public string Placeholder { get; set; } = "0";
    // 0=整数（円など・従来動作）／1以上=小数を許可・表示（数量・単価など）。
    [Parameter] public int Decimals { get; set; } = 0;

    private bool _focused;
    private string _editing = "";

    private string DispFmt => Decimals > 0 ? "#,0.######" : "#,0";
    private string EditFmt => Decimals > 0 ? "0.######" : "0";

    // 非フォーカス時はカンマ整形して表示、フォーカス中は入力内容をそのまま返す。
    private string DisplayValue => _focused ? _editing : Value.ToString(DispFmt);

    private void OnFocus()
    {
        _focused = true;
        // 0 のときは空欄から打ち始められるようにする（"0" を居座らせない）。
        _editing = Value == 0 ? "" : Value.ToString(EditFmt);
    }

    private async Task OnInput(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString()?.Replace(",", "") ?? "";
        _editing = raw;
        decimal.TryParse(raw, out var v);
        Value = v;
        await ValueChanged.InvokeAsync(v);
    }

    private async Task OnBlur()
    {
        _focused = false;
        // 空欄やパース不能は 0 に確定。
        if (!decimal.TryParse(_editing.Replace(",", ""), out var v)) v = 0;
        if (v != Value)
        {
            Value = v;
            await ValueChanged.InvokeAsync(v);
        }
    }
}
