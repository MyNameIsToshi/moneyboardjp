@inject LedgerService Svc

<div class="cat-head">
    <span>カード</span>
    <button class="btn" @onclick="Add">＋ 追加</button>
</div>

@if (!Ordered.Any())
{
    <div class="none">カードが登録されていません。</div>
}
else
{
    @foreach (var card in Ordered)
    {
        @if (IsMobile)
        {
            <button class="list-card" @onclick="() => OpenEdit(card.Id)">
                <div class="list-card-main">
                    <span class="list-card-name">@(string.IsNullOrEmpty(card.Name) ? "(名称未設定)" : card.Name)</span>
                </div>
                <div class="list-card-sub">
                    <span>@AccountName(card.AccountId)</span>
                    <span class="list-card-chev">›</span>
                </div>
            </button>
        }
        else
        {
        <div class="cat-row @(DragOverId == card.Id ? "drag-over" : "")"
             draggable="true"
             @ondragstart="() => OnDragStart(card.Id)"
             @ondragover:preventDefault="true"
             @ondragover="() => OnDragOver(card.Id)"
             @ondrop="() => OnDrop(card.Id)"
             @ondragend="OnDragEnd">
            <span class="drag-handle">⠿</span>
            <input class="cat-name" @bind="card.Name" @bind:after="Save" placeholder="カード名" />
            <select class="card-acct" @bind="card.AccountId" @bind:after="Save">
                <option value="">引き落とし口座を選択</option>
                @foreach (var a in Svc.ActiveAccounts)
                {
                    <option value="@a.Id">@a.Name</option>
                }
            </select>
            <button class="x" @onclick="() => AskDelete(card)">✕</button>
        </div>
        }
    }
}

<div class="foot" style="text-align:left;margin-top:10px">
    カードの利用明細合計が、選択した口座のその月の支出に反映されます（明細機能は今後追加）。
</div>

<ConfirmDialog IsVisible="@ShowConfirm"
               Title="カードを削除しますか？"
               Message="@ConfirmMessage"
               ConfirmText="削除する"
               OnConfirm="ExecuteDelete"
               OnCancel="CancelDelete" />

<WarnDialog IsVisible="@ShowNoAccountWarn"
            Title="口座が登録されていません"
            Messages="@(new List<string> { "カードを追加するには、先に口座を登録してください。" })"
            SubMessage=""
            OnClose="() => ShowNoAccountWarn = false" />

<!-- スマホ：サマリーカードのタップで開く編集シート -->
<BottomSheet IsVisible="@(Editing is not null)" Title="カードを編集" OnClose="CloseEdit">
    <ChildContent>
        @if (Editing is not null)
        {
            <div class="sheet-field">
                <label>カード名</label>
                <input @bind="Editing.Name" @bind:after="Save" placeholder="カード名" />
            </div>
            <div class="sheet-field">
                <label>引き落とし口座</label>
                <select @bind="Editing.AccountId" @bind:after="Save">
                    <option value="">引き落とし口座を選択</option>
                    @foreach (var a in Svc.ActiveAccounts)
                    {
                        <option value="@a.Id">@a.Name</option>
                    }
                </select>
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button class="btn danger" @onclick="DeleteEditing">削除</button>
        <button class="btn primary" style="margin-left:auto" @onclick="CloseEdit">完了</button>
    </FooterContent>
</BottomSheet>

@code {
    [CascadingParameter(Name = "IsMobile")] public bool IsMobile { get; set; }

    private IEnumerable<Card> Ordered => Svc.State.Cards.Where(c => !c.IsDeleted).OrderBy(c => c.SortOrder);

    // スマホ：編集シートで開いているカード（直接編集・即時保存）。
    private string? _editId;
    private bool _isNew;   // ＋追加で開いた新規カードか（未入力のまま閉じたら破棄する）
    private Card? Editing => _editId is null ? null : Svc.State.Cards.FirstOrDefault(c => c.Id == _editId);
    private void OpenEdit(string id) { _editId = id; _isNew = false; }

    private void CloseEdit()
    {
        // カード名が空のまま閉じた新規カードは追加しない（破棄）。
        if (_isNew && Editing is { } card && string.IsNullOrWhiteSpace(card.Name))
        {
            Svc.State.Cards.RemoveAll(c => c.Id == _editId);
            Save();
        }
        _editId = null;
        _isNew = false;
    }
    private string AccountName(string id) => Svc.ActiveAccounts.FirstOrDefault(a => a.Id == id)?.Name ?? "口座未選択";

    // シートから削除：シートを閉じてから確認ダイアログを出す（重なり順の都合）。
    private void DeleteEditing()
    {
        var card = Editing;
        _editId = null;
        if (card is not null) AskDelete(card);
    }

    // カード変更は当月以降の月次カード Debit を作り直してから保存する
    private void Save() { Svc.OnCardsChanged(); _ = Svc.SaveAsync(); }

    private bool ShowNoAccountWarn;

    private void Add()
    {
        // 口座が1件も無いとカードの引き落とし先が決められないため、先に口座登録を促す。
        if (!Svc.ActiveAccounts.Any()) { ShowNoAccountWarn = true; return; }
        var card = new Card
        {
            Name = "",
            AccountId = Svc.ActiveAccounts.FirstOrDefault()?.Id ?? "",
            SortOrder = Ordered.Count()
        };
        Svc.State.Cards.Add(card);
        Save();
        if (IsMobile) { _editId = card.Id; _isNew = true; }   // スマホは作成後すぐ編集シートを開く
    }

    // ── 削除（確認ダイアログで消えるデータを明示）──
    private bool ShowConfirm;
    private string? PendingDeleteId;
    private string ConfirmMessage = "";

    private void AskDelete(Card card)
    {
        var (count, total) = Svc.CardDeletionImpact(card.Id);
        var lines = $"「{card.Name}」を削除します。\n\n";
        lines += count > 0
            ? $"・当月以降の明細 {count} 件（¥{total:#,0}）と、口座の支出への反映が削除されます。\n"
            : "・当月以降に削除される明細はありません。\n";
        lines += "・過去の明細は履歴として残ります（統計のカード名も保持されます）。\n\n";
        lines += "この操作は取り消せません。";

        ConfirmMessage = lines;
        PendingDeleteId = card.Id;
        ShowConfirm = true;
    }

    // 当月以降の明細を除去しカード Debit を作り直す（過去月は履歴として凍結）。
    private void ExecuteDelete()
    {
        if (PendingDeleteId != null) { Svc.DeleteCard(PendingDeleteId); _ = Svc.SaveAsync(); }
        PendingDeleteId = null;
        ShowConfirm = false;
    }

    private void CancelDelete() { PendingDeleteId = null; ShowConfirm = false; }

    // ── ドラッグ＆ドロップ並び替え ──────────────────
    private string? DragSourceId;
    private string? DragOverId;

    private void OnDragStart(string id) => DragSourceId = id;
    private void OnDragOver(string id) => DragOverId = id;

    private void OnDrop(string targetId)
    {
        if (DragSourceId == null || DragSourceId == targetId) { OnDragEnd(); return; }

        var ordered = Ordered.ToList();
        var srcIdx = ordered.FindIndex(c => c.Id == DragSourceId);
        var tgtIdx = ordered.FindIndex(c => c.Id == targetId);
        if (srcIdx < 0 || tgtIdx < 0) { OnDragEnd(); return; }

        var item = ordered[srcIdx];
        ordered.RemoveAt(srcIdx);
        ordered.Insert(tgtIdx, item);
        for (int i = 0; i < ordered.Count; i++) ordered[i].SortOrder = i;

        OnDragEnd();
        Save();
    }

    private void OnDragEnd()
    {
        DragSourceId = null;
        DragOverId = null;
    }
}
