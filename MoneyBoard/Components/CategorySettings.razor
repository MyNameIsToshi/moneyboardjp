@inject LedgerService Svc

<div class="set-head">
    <span class="set-chip c-category msym">sell</span>
    <span class="set-title">カード明細カテゴリ</span>
    <button class="set-add" @onclick="Add"><span class="msym">add</span>追加</button>
</div>

@if (Svc.State.Categories.Count == 0)
{
    <div class="none">カテゴリが登録されていません。</div>
}
else
{
    <div class="set-list">
        @foreach (var c in Ordered)
        {
            @if (IsMobile)
            {
                <div class="list-card-wrap">
                    <button class="list-card" @onclick="() => OpenEdit(c.Id)">
                        <div class="cat-card-row">
                            <span class="cat-swatch" style="background:@c.Color"></span>
                            <span class="list-card-name">@(string.IsNullOrEmpty(c.Name) ? "(名称未設定)" : c.Name)</span>
                            <span class="list-card-chev msym">chevron_right</span>
                        </div>
                    </button>
                    <div class="list-card-move">
                        <button @onclick="() => Move(c, -1)" disabled="@(c == Ordered.First())" aria-label="上へ">▲</button>
                        <button @onclick="() => Move(c, 1)" disabled="@(c == Ordered.Last())" aria-label="下へ">▼</button>
                    </div>
                </div>
            }
            else
            {
                <div class="set-row cat-row @(DragOverId == c.Id ? "drag-over" : "")"
                     draggable="true"
                     @ondragstart="() => OnDragStart(c.Id)"
                     @ondragover:preventDefault="true"
                     @ondragover="() => OnDragOver(c.Id)"
                     @ondrop="() => OnDrop(c.Id)"
                     @ondragend="OnDragEnd">
                    <span class="drag-handle msym">drag_indicator</span>
                    <span class="cat-swatch" style="background:@c.Color"></span>
                    <input class="set-input cat-name" @bind="c.Name" @bind:after="Save" placeholder="カテゴリ名" />
                    <div class="cat-palette">
                        @foreach (var color in Palette)
                        {
                            <button class="cat-color @(c.Color == color ? "sel" : "")"
                                    style="background:@color"
                                    @onclick="() => SetColor(c, color)" title="@color"></button>
                        }
                    </div>
                    <button class="set-del" @onclick="() => Remove(c.Id)" title="削除"><span class="msym">close</span></button>
                </div>
            }
        }
    </div>
}

<div class="set-note">
    カテゴリ未設定の明細は「未分類（灰色）」として扱われます。
</div>

<!-- スマホ：サマリーカードのタップで開く編集シート -->
<BottomSheet IsVisible="@(Editing is not null)" Title="カテゴリを編集" OnClose="CloseEdit">
    <ChildContent>
        @if (Editing is not null)
        {
            <div class="sheet-field">
                <label>カテゴリ名</label>
                <input @bind="Editing.Name" @bind:after="Save" placeholder="カテゴリ名" />
            </div>
            <div class="sheet-field">
                <label>色</label>
                <div class="cat-palette">
                    @foreach (var color in Palette)
                    {
                        <button class="cat-color @(Editing.Color == color ? "sel" : "")"
                                style="background:@color"
                                @onclick="() => SetColor(Editing, color)" title="@color"></button>
                    }
                </div>
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button class="btn danger" @onclick="DeleteEditing">削除</button>
        <button class="btn primary" style="margin-left:auto" @onclick="CloseEdit">完了</button>
    </FooterContent>
</BottomSheet>

@code {
    [CascadingParameter(Name = "IsMobile")] public bool IsMobile { get; set; }

    // スマホ：編集シートで開いているカテゴリ。既存は State の実体を直接編集（即時保存）、
    // ＋追加は未コミットのドラフトを編集し、決定（完了）時にだけ State へ追加・保存する。
    private string? _editId;
    private bool _isNew;        // ＋追加のドラフトを編集中か
    private Category? _draft;   // ＋追加のドラフト（決定するまで State に入れない）
    private Category? Editing => _isNew ? _draft : (_editId is null ? null : Svc.State.Categories.FirstOrDefault(c => c.Id == _editId));
    private void OpenEdit(string id) { _editId = id; _isNew = false; _draft = null; }

    private void CloseEdit()
    {
        // ＋追加のドラフトは「決定」時にだけコミット。カテゴリ名が空なら破棄（State には何も作らない）。
        if (_isNew)
        {
            var c = _draft;
            _isNew = false; _draft = null; _editId = null;
            if (c is not null && !string.IsNullOrWhiteSpace(c.Name)) { Svc.State.Categories.Add(c); Save(); }
            return;
        }
        _editId = null;
    }

    // シートから削除：ドラフトは破棄、既存はシートを閉じてから削除（カテゴリは確認なしで即削除＝従来挙動）。
    private void DeleteEditing()
    {
        if (_isNew) { _isNew = false; _draft = null; _editId = null; return; }
        var id = _editId;
        _editId = null;
        if (id != null) Remove(id);
    }

    // 12色パレット
    private static readonly string[] Palette =
    {
        "#ef4444", "#f97316", "#f59e0b", "#eab308", "#84cc16", "#22c55e",
        "#14b8a6", "#06b6d4", "#3b82f6", "#8b5cf6", "#ec4899", "#78716c"
    };

    private IEnumerable<Category> Ordered => Svc.State.Categories.OrderBy(c => c.SortOrder);

    // ドラフト編集中（_isNew）は永続化しない（決定時に State へ追加してから保存）。
    private void Save() { if (_isNew) return; _ = Svc.SaveAsync(); }

    private void Add()
    {
        // 未使用の色を優先的に割り当てる
        var used = Svc.State.Categories.Select(c => c.Color).ToHashSet();
        var color = Palette.FirstOrDefault(p => !used.Contains(p)) ?? Palette[0];
        var c = new Category
        {
            Name = "",
            Color = color,
            SortOrder = Svc.State.Categories.Count
        };
        // スマホはドラフトとして編集シートを開く（決定時にコミット）。PCは従来どおり即追加＋インライン編集。
        if (IsMobile) { _draft = c; _editId = c.Id; _isNew = true; }
        else { Svc.State.Categories.Add(c); Save(); }
    }

    private void SetColor(Category c, string color) { c.Color = color; Save(); }

    // スマホ：▲▼ で並べ替え（dir=-1 上 / +1 下）。SortOrder を 0..n に振り直す。
    private void Move(Category c, int dir)
    {
        var list = Svc.State.Categories.OrderBy(x => x.SortOrder).ToList();
        int i = list.IndexOf(c);
        int j = i + dir;
        if (i < 0 || j < 0 || j >= list.Count) return;
        (list[i], list[j]) = (list[j], list[i]);
        for (int k = 0; k < list.Count; k++) list[k].SortOrder = k;
        Save();
    }

    private void Remove(string id) { Svc.State.Categories.RemoveAll(c => c.Id == id); Save(); }

    // ── ドラッグ＆ドロップ並び替え ──────────────────
    private string? DragSourceId;
    private string? DragOverId;

    private void OnDragStart(string id) => DragSourceId = id;
    private void OnDragOver(string id) => DragOverId = id;

    private void OnDrop(string targetId)
    {
        if (DragSourceId == null || DragSourceId == targetId) { OnDragEnd(); return; }

        var ordered = Svc.State.Categories.OrderBy(c => c.SortOrder).ToList();
        var srcIdx = ordered.FindIndex(c => c.Id == DragSourceId);
        var tgtIdx = ordered.FindIndex(c => c.Id == targetId);
        if (srcIdx < 0 || tgtIdx < 0) { OnDragEnd(); return; }

        var item = ordered[srcIdx];
        ordered.RemoveAt(srcIdx);
        ordered.Insert(tgtIdx, item);

        // SortOrder を連番に振り直す
        for (int i = 0; i < ordered.Count; i++) ordered[i].SortOrder = i;

        OnDragEnd();
        Save();
    }

    private void OnDragEnd()
    {
        DragSourceId = null;
        DragOverId = null;
    }
}
